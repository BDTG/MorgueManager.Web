@page "/admin/storages"
@layout Components.Layout.AdminLayout
@inject NavigationManager Navigation
@inject MorgueManager.Web.Services.TourService TourService
@inject Supabase.Client Supabase
@inject IJSRuntime JS

<div>
    <div style="display: flex; flex-wrap: wrap; justify-content: space-between; align-items: center; gap: 16px; margin-bottom: 24px;">
        <div>
            <div class="font-ui" style="font-size: 12px; color: var(--text-muted); margin-bottom: 4px;">Dashboard / Sơ đồ Ngăn tủ</div>
            <h1 class="font-ui" style="font-size: 22px; font-weight: 700; margin: 0; color: var(--text-primary);">🗄️ Sơ đồ Ngăn tủ</h1>
        </div>
        <div style="display: flex; gap: 8px; flex-wrap: wrap;">
            <button @onclick="() => _showTemp = !_showTemp" class="font-ui" style="padding: 8px 16px; border-radius: 8px; font-size: 12px; cursor: pointer; border: 1px solid var(--border-primary); color: @(_showTemp ? "var(--success)" : "var(--text-secondary)"); background: transparent;">🌡️ @(_showTemp ? "Ẩn" : "Hiện") nhiệt độ</button>
            <button @onclick="NavToTemperature" class="font-ui" style="padding: 8px 16px; border-radius: 8px; font-size: 12px; cursor: pointer; border: 1px solid var(--candle); color: var(--candle); background: transparent;">⚙️ Điều chỉnh nhiệt độ</button>
            <button class="font-ui" style="padding: 8px 16px; border-radius: 8px; font-size: 12px; cursor: pointer; border: 1px solid var(--border-primary); color: var(--text-secondary); background: transparent;">📊 Thống kê</button>
        </div>
    </div>

    <!-- Legend -->
    @{
        var allSlots = _zoneASlots.Concat(_zoneBSlots).Concat(_zoneCSlots).ToList();
        var emptyCount = allSlots.Count(s => s.Status == Models.SlotStatus.Empty);
        var occupiedCount = allSlots.Count(s => s.Status == Models.SlotStatus.Occupied);
        var cleaningCount = allSlots.Count(s => s.Status == Models.SlotStatus.Cleaning);
        var maintCount = allSlots.Count(s => s.Status == Models.SlotStatus.Maintenance);
        var pendingCount = allSlots.Count(s => s.Status == Models.SlotStatus.Pending);
        var totalCount = allSlots.Count;
        var usagePercent = totalCount > 0 ? (occupiedCount * 100 / totalCount) : 0;
    }
    <div id="tour-storage-legend" style="display: flex; flex-wrap: wrap; justify-content: space-between; align-items: center; padding: 12px 16px; margin-bottom: 24px; border-radius: 8px; background-color: var(--bg-card); border: 1px solid var(--border-primary);">
        <div style="display: flex; gap: 20px; flex-wrap: wrap; align-items: center;">
            <span class="font-ui" style="font-size: 12px; color: var(--text-muted);"><span style="color: #10B981;">🟢</span> Trống (@emptyCount)</span>
            <span class="font-ui" style="font-size: 12px; color: var(--text-muted);"><span style="color: #EF4444;">🔴</span> Đang sử dụng (@occupiedCount)</span>
            <span class="font-ui" style="font-size: 12px; color: var(--text-muted);"><span style="color: #EC4899;">🌸</span> Đang xử lý (@pendingCount)</span>
            <span class="font-ui" style="font-size: 12px; color: var(--text-muted);"><span style="color: #F59E0B;">🟡</span> Chờ vệ sinh (@cleaningCount)</span>
            <span class="font-ui" style="font-size: 12px; color: var(--text-muted);"><span style="color: #6366F1;">🟣</span> Bảo trì (@maintCount)</span>
            <span class="font-ui" style="font-size: 12px; color: var(--text-muted); padding-left: 8px; border-left: 1px solid var(--border-primary); margin-left: 8px; display: inline-flex; align-items: center; gap: 4px;">
                <span style="font-size: 14px;">❄️</span> Khu C (Lạnh sâu - Chuyên dụng)
            </span>
        </div>
        <span class="font-ui" style="font-size: 12px; color: var(--text-muted);">Tổng: @totalCount ngăn | Sử dụng: @usagePercent%</span>
    </div>

    <!-- Zone A -->
    <div id="tour-storage-zone-a">
        <StorageZone Name="Khu A — Tủ lạnh chính (Mát)" TargetTemp="2" CurrentTemp="@_zoneATemp" ShowTemp="_showTemp" Slots="@_zoneASlots" OnSlotClick="SlotClicked" />
    </div>

    <!-- Zone B -->
    <StorageZone Name="Khu B — Tủ lạnh phụ (Mát)" TargetTemp="2" CurrentTemp="@_zoneBTemp" ShowTemp="_showTemp" Slots="@_zoneBSlots" OnSlotClick="SlotClicked" />

    <!-- Zone C -->
    <StorageZone Name="Khu C — Tủ cấp đông chuyên dụng (Thi thể không nguyên vẹn / Lạnh sâu)" TargetTemp="-5" CurrentTemp="@_zoneCTemp" ShowTemp="_showTemp" Slots="@_zoneCSlots" OnSlotClick="SlotClicked" />
</div>

@if (_selectedSlot is not null)
{
    <Modal OnClose="() => _selectedSlot = null">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px;">
            <h2 class="font-ui" style="font-size: 18px; font-weight: 700; margin: 0; color: var(--text-primary);">🗄️ Chi tiết Ngăn @_selectedSlot.Id</h2>
            <button @onclick="() => _selectedSlot = null" style="background: none; border: none; color: var(--text-muted); font-size: 20px; cursor: pointer;">✕</button>
        </div>
        <div style="margin-bottom: 24px;">
            @if (_selectedSlot.Id.StartsWith("C"))
            {
                <div style="margin-bottom: 16px; padding: 12px; border-radius: 8px; background-color: rgba(239, 68, 68, 0.15); border: 1px solid rgba(239, 68, 68, 0.25); color: #F87171; font-size: 13px;" class="font-ui">
                    ⚠️ <strong>Lưu ý Khu C:</strong> Ngăn tủ bảo quản đặc biệt (Lạnh sâu -5°C) dành riêng cho các trường hợp thi thể không nguyên vẹn hoặc yêu cầu vệ sinh dịch tễ nghiêm ngặt.
                </div>
            }
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
                <div><div class="font-ui" style="font-size: 11px; color: var(--text-muted); text-transform: uppercase;">Ngăn</div><div class="font-ui" style="font-size: 14px; color: var(--text-primary);">@_selectedSlot.Id</div></div>
                <div><div class="font-ui" style="font-size: 11px; color: var(--text-muted); text-transform: uppercase;">Trạng thái</div><div class="font-ui" style="font-size: 14px; color: @(_selectedSlot.Status == Models.SlotStatus.Occupied ? "#EF4444" : _selectedSlot.Status == Models.SlotStatus.Empty ? "#10B981" : _selectedSlot.Status == Models.SlotStatus.Cleaning ? "#F59E0B" : _selectedSlot.Status == Models.SlotStatus.Pending ? "#EC4899" : "#6366F1");">@(_selectedSlot.Status == Models.SlotStatus.Occupied ? "Đang sử dụng" : _selectedSlot.Status == Models.SlotStatus.Empty ? "Trống" : _selectedSlot.Status == Models.SlotStatus.Cleaning ? "Chờ vệ sinh" : _selectedSlot.Status == Models.SlotStatus.Pending ? "Yêu cầu thuê" : "Bảo trì")</div></div>
                <div><div class="font-ui" style="font-size: 11px; color: var(--text-muted); text-transform: uppercase;">Nhiệt độ</div><div class="font-ui" style="font-size: 14px; color: @(_selectedSlot.Temp > 6 ? "var(--danger)" : _selectedSlot.Temp < 0 ? "var(--ice)" : "var(--success)");">@_selectedSlot.Temp.ToString("F1")°C</div></div>
                <div><div class="font-ui" style="font-size: 11px; color: var(--text-muted); text-transform: uppercase;">Thời gian lưu</div><div class="font-ui" style="font-size: 14px; color: var(--text-primary);">@_selectedSlot.DaysStored ngày</div></div>
                @if (_selectedSlot.Status == Models.SlotStatus.Occupied)
                {
                    <div style="grid-column: 1/-1;"><div class="font-ui" style="font-size: 11px; color: var(--text-muted); text-transform: uppercase;">Thi thể đang lưu trữ</div><div class="font-ui" style="font-size: 14px; color: var(--text-primary); font-weight: 600;">@(_selectedSlot.CorpseName ?? "Không rõ tên")</div></div>
                }
            </div>
        </div>
        <div style="display: flex; gap: 8px; flex-wrap: wrap;">
            @if (_selectedSlot.Status == Models.SlotStatus.Occupied)
            {
                <button @onclick="NavToCorpseDetail" class="font-ui" style="padding: 8px 16px; border-radius: 8px; font-size: 12px; cursor: pointer; border: 1px solid var(--ice); color: var(--ice); background: transparent;">👁️ Xem thi thể</button>
                <button @onclick="StartHandover" class="font-ui" style="padding: 8px 16px; border-radius: 8px; font-size: 12px; cursor: pointer; border: 1px solid var(--success); color: var(--success); background: transparent;">📋 Bàn giao</button>
                <button @onclick="() => _showTransferForm = !_showTransferForm" class="font-ui" style="padding: 8px 16px; border-radius: 8px; font-size: 12px; cursor: pointer; border: 1px solid var(--candle); color: var(--candle); background: transparent;">🔄 Chuyển ngăn</button>
            }
            else
            {
                <button class="font-ui" style="padding: 8px 16px; border-radius: 8px; font-size: 12px; opacity: 0.5; border: 1px solid var(--border-primary); color: var(--text-muted); background: transparent; cursor: not-allowed;" disabled>👁️ Xem thi thể</button>
                <button class="font-ui" style="padding: 8px 16px; border-radius: 8px; font-size: 12px; opacity: 0.5; border: 1px solid var(--border-primary); color: var(--text-muted); background: transparent; cursor: not-allowed;" disabled>📋 Bàn giao</button>
                <button class="font-ui" style="padding: 8px 16px; border-radius: 8px; font-size: 12px; opacity: 0.5; border: 1px solid var(--border-primary); color: var(--text-muted); background: transparent; cursor: not-allowed;" disabled>🔄 Chuyển ngăn</button>
            }

            @if (_selectedSlot.Status == Models.SlotStatus.Empty || _selectedSlot.Status == Models.SlotStatus.Cleaning)
            {
                <button @onclick='() => ToggleSlotStatusAsync(_selectedSlot.Id, "Cleaning")' class="font-ui" style="padding: 8px 16px; border-radius: 8px; font-size: 12px; cursor: pointer; border: 1px solid var(--candle-deep); color: var(--candle-deep); background: @(_selectedSlot.Status == Models.SlotStatus.Cleaning ? "rgba(245,158,11,0.15)" : "transparent");">
                    🧹 @(_selectedSlot.Status == Models.SlotStatus.Cleaning ? "Xong vệ sinh" : "Đánh dấu vệ sinh")
                </button>
            }
            else
            {
                <button class="font-ui" style="padding: 8px 16px; border-radius: 8px; font-size: 12px; opacity: 0.5; border: 1px solid var(--border-primary); color: var(--text-muted); background: transparent; cursor: not-allowed;" disabled>🧹 Đánh dấu vệ sinh</button>
            }

            @if (_selectedSlot.Status == Models.SlotStatus.Empty || _selectedSlot.Status == Models.SlotStatus.Maintenance)
            {
                <button @onclick='() => ToggleSlotStatusAsync(_selectedSlot.Id, "Maintenance")' class="font-ui" style="padding: 8px 16px; border-radius: 8px; font-size: 12px; cursor: pointer; border: 1px solid var(--info); color: var(--info); background: @(_selectedSlot.Status == Models.SlotStatus.Maintenance ? "rgba(99,102,241,0.15)" : "transparent");">
                    🔧 @(_selectedSlot.Status == Models.SlotStatus.Maintenance ? "Hoàn thành bảo trì" : "Bảo trì")
                </button>
            }
            else
            {
                <button class="font-ui" style="padding: 8px 16px; border-radius: 8px; font-size: 12px; opacity: 0.5; border: 1px solid var(--border-primary); color: var(--text-muted); background: transparent; cursor: not-allowed;" disabled>🔧 Bảo trì</button>
            }
        </div>

        @if (_showTransferForm)
        {
            <div style="margin-top: 16px; padding: 16px; border-radius: 8px; background-color: var(--bg-card); border: 1px solid var(--border-primary);">
                <div class="font-ui" style="font-size: 12px; color: var(--text-muted); margin-bottom: 8px;">Chọn ngăn mới cho @_selectedSlot.CorpseName</div>
                <div style="display: flex; gap: 8px; align-items: center;">
                    <select @bind="_transferTargetSlotId" class="cold-input font-ui text-sm" style="flex: 1; background-color: rgba(0,0,0,0.3); border: 1px solid var(--border-primary); color: var(--text-primary); padding: 6px; outline: none; border-radius: 4px;">
                        <option value="">-- Chọn ngăn trống --</option>
                        @foreach (var emptySlot in GetEmptySlots())
                        {
                            <option value="@emptySlot">@emptySlot</option>
                        }
                    </select>
                    <button @onclick="ConfirmTransferAsync" class="font-ui" style="padding: 6px 12px; border-radius: 4px; font-size: 12px; cursor: pointer; background: var(--success); color: white; border: none;">Xác nhận</button>
                    <button @onclick="() => _showTransferForm = false" class="font-ui" style="padding: 6px 12px; border-radius: 4px; font-size: 12px; cursor: pointer; background: transparent; color: var(--text-muted); border: 1px solid var(--border-primary);">Hủy</button>
                </div>
                @if (!string.IsNullOrEmpty(_transferError))
                {
                    <div class="font-ui" style="font-size: 11px; color: var(--danger); margin-top: 8px;">@_transferError</div>
                }
            </div>
        }
    </Modal>
}

<ConfirmDialog IsVisible="@_showHandoverConfirm"
               Title="Xác nhận bàn giao thi thể"
               Message="@($"Xác nhận bàn giao thi thể {_handoverCorpse?.Name} ({_handoverCorpse?.CaseId}) cho thân nhân và giải phóng ngăn tủ {_selectedSlot?.Id}?")"
               ConfirmText="Xác nhận bàn giao"
               CancelText="Hủy"
               Type="success"
               OnConfirm="ConfirmHandover"
               OnCancel="() => _showHandoverConfirm = false" />

@if (_showToast)
{
    <Toast Message="@_toastMessage" Type="success" />
}

@code {
    private bool _showTemp = true;
    private double _zoneATemp = 2.3;
    private double _zoneBTemp = 3.8;
    private double _zoneCTemp = -4.8;
    private Models.StorageSlot? _selectedSlot;

    private List<Models.StorageSlot> _zoneASlots = new();
    private List<Models.StorageSlot> _zoneBSlots = new();
    private List<Models.StorageSlot> _zoneCSlots = new();

    private List<ContactModel> _contactRequests = new();
    private bool _showTransferForm = false;
    private string _transferTargetSlotId = "";
    private string _transferError = "";
    private bool _showHandoverConfirm = false;
    private Models.Corpse? _handoverCorpse;
    private bool _showToast = false;
    private string _toastMessage = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadContactRequestsAsync();
        await LoadLocalSlotStatusesAsync();
        await LoadSlotsFromSupabaseAsync();
    }

    private async Task LoadContactRequestsAsync()
    {
        _contactRequests.Clear();
        // 1. Try loading from Supabase
        try
        {
            var response = await Supabase.From<ContactModel>().Get();
            if (response?.Models != null && response.Models.Count > 0)
            {
                _contactRequests.AddRange(response.Models);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine("Supabase load failed in StorageMap: " + ex.Message);
        }

        // 2. Load from LocalStorage and merge
        try
        {
            var localDataJson = await JS.InvokeAsync<string>("localStorage.getItem", "local_contact_requests");
            if (!string.IsNullOrEmpty(localDataJson))
            {
                List<ContactModelDto>? localRequests = null;
                try
                {
                    localRequests = System.Text.Json.JsonSerializer.Deserialize<List<ContactModelDto>>(localDataJson);
                }
                catch (Exception ex)
                {
                    Console.WriteLine("Failed to deserialize local storage contact requests in StorageMap: " + ex.Message);
                }

                if (localRequests != null && localRequests.Count > 0)
                {
                    foreach (var lrdto in localRequests)
                    {
                        var lr = lrdto.ToModel();
                        if (!_contactRequests.Any(r => r.Id == lr.Id || (r.Name == lr.Name && r.Email == lr.Email && r.Message == lr.Message)))
                        {
                            _contactRequests.Add(lr);
                        }
                    }
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine("Error loading local requests in StorageMap: " + ex.Message);
        }
    }

    private void ApplyRequestOverlay(List<Models.StorageSlot> slots)
    {
        foreach (var slot in slots)
        {
            // Only overlay requests if the slot is currently Empty
            if (slot.Status == Models.SlotStatus.Empty)
            {
                // Find the latest request for this slot
                var matchingRequest = _contactRequests
                    .Where(r => r.StorageSlot == slot.Id)
                    .OrderByDescending(r => r.CreatedAt)
                    .FirstOrDefault();

                if (matchingRequest != null)
                {
                    if (matchingRequest.Status == "Đã hoàn thành")
                    {
                        slot.Status = Models.SlotStatus.Occupied;
                        slot.CorpseName = matchingRequest.Name;
                        slot.PackageName = matchingRequest.PackageName;
                    }
                    else if (matchingRequest.Status == "Chưa xử lý" || matchingRequest.Status == "Đang xử lý")
                    {
                        // Check if the request is within 24 hours (UTC)
                        var limitTime = DateTime.UtcNow.AddDays(-1);
                        if (matchingRequest.CreatedAt >= limitTime)
                        {
                            slot.Status = Models.SlotStatus.Pending;
                            slot.CorpseName = matchingRequest.Name;
                            slot.PackageName = matchingRequest.PackageName;
                        }
                    }
                }
            }
        }
    }

    private async Task LoadSlotsFromSupabaseAsync()
    {
        try
        {
            var response = await Supabase.From<Corpse>().Get();
            var corpses = response.Models ?? new List<Corpse>();

            _zoneASlots = Enumerable.Range(1, 10).Select(i =>
            {
                var slotId = $"A-{i:D2}";
                var corpse = corpses.FirstOrDefault(c => c.StorageSlot == slotId && c.Status == "Lưu kho");
                return new Models.StorageSlot
                {
                    Id = slotId,
                    Zone = "A",
                    Status = corpse != null ? Models.SlotStatus.Occupied : Models.SlotStatus.Empty,
                    Temp = 2.0 + (i * 0.1),
                    CorpseName = corpse?.Name,
                    CorpseId = corpse?.Id,
                    DaysStored = corpse != null && DateTime.TryParse(corpse.DateAdmitted, out var dt) ? (DateTime.Now - dt).Days : 0,
                    PackageName = corpse?.PackageName,
                    LastUpdate = $"{DateTime.Now:HH:mm}"
                };
            }).ToList();

            _zoneBSlots = Enumerable.Range(1, 10).Select(i =>
            {
                var slotId = $"B-{i:D2}";
                var corpse = corpses.FirstOrDefault(c => c.StorageSlot == slotId && c.Status == "Lưu kho");
                return new Models.StorageSlot
                {
                    Id = slotId,
                    Zone = "B",
                    Status = corpse != null ? Models.SlotStatus.Occupied : Models.SlotStatus.Empty,
                    Temp = 2.5 + (i * 0.1),
                    CorpseName = corpse?.Name,
                    CorpseId = corpse?.Id,
                    DaysStored = corpse != null && DateTime.TryParse(corpse.DateAdmitted, out var dt) ? (DateTime.Now - dt).Days : 0,
                    PackageName = corpse?.PackageName,
                    LastUpdate = $"{DateTime.Now:HH:mm}"
                };
            }).ToList();

            _zoneCSlots = Enumerable.Range(1, 5).Select(i =>
            {
                var slotId = $"C-{i:D2}";
                var corpse = corpses.FirstOrDefault(c => c.StorageSlot == slotId && c.Status == "Lưu kho");
                return new Models.StorageSlot
                {
                    Id = slotId,
                    Zone = "C",
                    Status = corpse != null ? Models.SlotStatus.Occupied : Models.SlotStatus.Empty,
                    Temp = -5.0 + (i * 0.1),
                    CorpseName = corpse?.Name,
                    CorpseId = corpse?.Id,
                    DaysStored = corpse != null && DateTime.TryParse(corpse.DateAdmitted, out var dt) ? (DateTime.Now - dt).Days : 0,
                    PackageName = corpse?.PackageName,
                    LastUpdate = $"{DateTime.Now:HH:mm}"
                };
            }).ToList();

            // Apply overlay for contact requests
            ApplyRequestOverlay(_zoneASlots);
            ApplyRequestOverlay(_zoneBSlots);
            ApplyRequestOverlay(_zoneCSlots);

            // Apply overlay for local slot statuses (cleaning, maintenance)
            ApplyLocalSlotStatusesOverlay(_zoneASlots);
            ApplyLocalSlotStatusesOverlay(_zoneBSlots);
            ApplyLocalSlotStatusesOverlay(_zoneCSlots);
        }
        catch (Exception ex)
        {
            Console.WriteLine("Error loading slots from Supabase: " + ex.Message);
            InitializeDummySlots();
        }
    }

    private void InitializeDummySlots()
    {
        _zoneASlots = Enumerable.Range(1, 10).Select(i => new Models.StorageSlot
        {
            Id = $"A-{i:D2}", Zone = "A",
            Status = i <= 5 ? Models.SlotStatus.Occupied : Models.SlotStatus.Empty,
            Temp = 1.8 + (i * 0.3),
            CorpseName = i <= 5 ? $"Nguyễn Văn {i}" : null,
            CorpseId = i <= 5 ? i : null,
            DaysStored = i * 3,
            LastUpdate = $"{DateTime.Now:HH:mm}",
        }).ToList();

        _zoneBSlots = Enumerable.Range(1, 10).Select(i => new Models.StorageSlot
        {
            Id = $"B-{i:D2}", Zone = "B",
            Status = i <= 3 ? Models.SlotStatus.Occupied : Models.SlotStatus.Empty,
            Temp = 3.0 + (i * 0.4),
            CorpseName = i <= 3 ? $"Trần Thị {i}" : null,
            CorpseId = i <= 3 ? i + 5 : null,
            DaysStored = i * 2,
            LastUpdate = $"{DateTime.Now:HH:mm}",
        }).ToList();

        _zoneCSlots = Enumerable.Range(1, 5).Select(i => new Models.StorageSlot
        {
            Id = $"C-{i:D2}", Zone = "C",
            Status = i <= 2 ? Models.SlotStatus.Occupied : Models.SlotStatus.Empty,
            Temp = -5.4 + (i * 0.2),
            CorpseName = i == 1 ? "Thi thể MC-2026-0128" : i == 2 ? "Bộ phận thi thể MC-2026-0129" : null,
            CorpseId = i <= 2 ? i + 8 : null,
            DaysStored = i * 4,
            LastUpdate = $"{DateTime.Now:HH:mm}",
        }).ToList();

        // Apply overlay for contact requests
        ApplyRequestOverlay(_zoneASlots);
        ApplyRequestOverlay(_zoneBSlots);
        ApplyRequestOverlay(_zoneCSlots);

        // Apply overlay for local slot statuses (cleaning, maintenance)
        ApplyLocalSlotStatusesOverlay(_zoneASlots);
        ApplyLocalSlotStatusesOverlay(_zoneBSlots);
        ApplyLocalSlotStatusesOverlay(_zoneCSlots);
    }

    private Dictionary<string, string> _localSlotStatuses = new();

    private async Task LoadLocalSlotStatusesAsync()
    {
        try
        {
            var json = await JS.InvokeAsync<string>("localStorage.getItem", "local_slot_statuses");
            if (!string.IsNullOrEmpty(json))
            {
                _localSlotStatuses = System.Text.Json.JsonSerializer.Deserialize<Dictionary<string, string>>(json) ?? new();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine("Error loading local slot statuses: " + ex.Message);
        }
    }

    private void ApplyLocalSlotStatusesOverlay(List<Models.StorageSlot> slots)
    {
        foreach (var slot in slots)
        {
            // Only apply if the slot is currently Empty (not occupied by database corpse or request)
            if (slot.Status == Models.SlotStatus.Empty)
            {
                if (_localSlotStatuses.TryGetValue(slot.Id, out var statusStr))
                {
                    if (statusStr == "Cleaning")
                    {
                        slot.Status = Models.SlotStatus.Cleaning;
                    }
                    else if (statusStr == "Maintenance")
                    {
                        slot.Status = Models.SlotStatus.Maintenance;
                    }
                }
            }
        }
    }

    private async Task ToggleSlotStatusAsync(string slotId, string statusToToggle)
    {
        if (_localSlotStatuses.TryGetValue(slotId, out var currentStatus) && currentStatus == statusToToggle)
        {
            _localSlotStatuses.Remove(slotId);
        }
        else
        {
            _localSlotStatuses[slotId] = statusToToggle;
        }

        try
        {
            await JS.InvokeVoidAsync("localStorage.setItem", "local_slot_statuses", System.Text.Json.JsonSerializer.Serialize(_localSlotStatuses));
        }
        catch (Exception ex)
        {
            Console.WriteLine("Error saving slot status to localStorage: " + ex.Message);
        }

        // Reload slots to update UI
        await LoadSlotsFromSupabaseAsync();
        
        // Also update the selected slot reference to reflect the changes in the modal!
        var allSlots = _zoneASlots.Concat(_zoneBSlots).Concat(_zoneCSlots).ToList();
        _selectedSlot = allSlots.FirstOrDefault(s => s.Id == slotId);
        
        StateHasChanged();
    }

    private void NavToCorpseDetail()
    {
        if (_selectedSlot != null && _selectedSlot.CorpseId.HasValue)
        {
            Navigation.NavigateTo($"/admin/corpses/{_selectedSlot.CorpseId.Value}");
        }
