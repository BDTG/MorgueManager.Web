@page "/admin/storages"
@layout Components.Layout.AdminLayout
@inject NavigationManager Navigation
@inject MorgueManager.Web.Services.TourService TourService
@inject Supabase.Client Supabase

<div>
    <div style="display: flex; flex-wrap: wrap; justify-content: space-between; align-items: center; gap: 16px; margin-bottom: 24px;">
        <div>
            <div class="font-ui" style="font-size: 12px; color: var(--text-muted); margin-bottom: 4px;">Dashboard / Sơ đồ Ngăn tủ</div>
            <h1 class="font-ui" style="font-size: 22px; font-weight: 700; margin: 0; color: var(--text-primary);">🗄️ Sơ đồ Ngăn tủ</h1>
        </div>
        <div style="display: flex; gap: 8px; flex-wrap: wrap;">
            <button @onclick="() => _showTemp = !_showTemp" class="font-ui" style="padding: 8px 16px; border-radius: 8px; font-size: 12px; cursor: pointer; border: 1px solid var(--border-primary); color: @(_showTemp ? "var(--success)" : "var(--text-secondary)"); background: transparent;">🌡️ @(_showTemp ? "Ẩn" : "Hiện") nhiệt độ</button>
            <button @onclick="NavToTemperature" class="font-ui" style="padding: 8px 16px; border-radius: 8px; font-size: 12px; cursor: pointer; border: 1px solid var(--candle); color: var(--candle); background: transparent;">⚙️ Điều chỉnh nhiệt độ</button>
            <button class="font-ui" style="padding: 8px 16px; border-radius: 8px; font-size: 12px; cursor: pointer; border: 1px solid var(--border-primary); color: var(--text-secondary); background: transparent;">📊 Thống kê</button>
        </div>
    </div>

    <!-- Legend -->
    @{
        var allSlots = _zoneASlots.Concat(_zoneBSlots).Concat(_zoneCSlots).ToList();
        var emptyCount = allSlots.Count(s => s.Status == Models.SlotStatus.Empty);
        var occupiedCount = allSlots.Count(s => s.Status == Models.SlotStatus.Occupied);
        var cleaningCount = allSlots.Count(s => s.Status == Models.SlotStatus.Cleaning);
        var maintCount = allSlots.Count(s => s.Status == Models.SlotStatus.Maintenance);
        var totalCount = allSlots.Count;
        var usagePercent = totalCount > 0 ? (occupiedCount * 100 / totalCount) : 0;
    }
    <div id="tour-storage-legend" style="display: flex; flex-wrap: wrap; justify-content: space-between; align-items: center; padding: 12px 16px; margin-bottom: 24px; border-radius: 8px; background-color: var(--bg-card); border: 1px solid var(--border-primary);">
        <div style="display: flex; gap: 20px; flex-wrap: wrap; align-items: center;">
            <span class="font-ui" style="font-size: 12px; color: var(--text-muted);"><span style="color: #10B981;">🟢</span> Trống (@emptyCount)</span>
            <span class="font-ui" style="font-size: 12px; color: var(--text-muted);"><span style="color: #EF4444;">🔴</span> Đang sử dụng (@occupiedCount)</span>
            <span class="font-ui" style="font-size: 12px; color: var(--text-muted);"><span style="color: #F59E0B;">🟡</span> Chờ vệ sinh (@cleaningCount)</span>
            <span class="font-ui" style="font-size: 12px; color: var(--text-muted);"><span style="color: #6366F1;">🟣</span> Bảo trì (@maintCount)</span>
            <span class="font-ui" style="font-size: 12px; color: var(--text-muted); padding-left: 8px; border-left: 1px solid var(--border-primary); margin-left: 8px; display: inline-flex; align-items: center; gap: 4px;">
                <span style="font-size: 14px;">❄️</span> Khu C (Lạnh sâu - Chuyên dụng)
            </span>
        </div>
        <span class="font-ui" style="font-size: 12px; color: var(--text-muted);">Tổng: @totalCount ngăn | Sử dụng: @usagePercent%</span>
    </div>

    <!-- Zone A -->
    <div id="tour-storage-zone-a">
        <StorageZone Name="Khu A — Tủ lạnh chính (Mát)" TargetTemp="2" CurrentTemp="@_zoneATemp" ShowTemp="_showTemp" Slots="@_zoneASlots" OnSlotClick="SlotClicked" />
    </div>

    <!-- Zone B -->
    <StorageZone Name="Khu B — Tủ lạnh phụ (Mát)" TargetTemp="2" CurrentTemp="@_zoneBTemp" ShowTemp="_showTemp" Slots="@_zoneBSlots" OnSlotClick="SlotClicked" />

    <!-- Zone C -->
    <StorageZone Name="Khu C — Tủ cấp đông chuyên dụng (Thi thể không nguyên vẹn / Lạnh sâu)" TargetTemp="-5" CurrentTemp="@_zoneCTemp" ShowTemp="_showTemp" Slots="@_zoneCSlots" OnSlotClick="SlotClicked" />
</div>

@if (_selectedSlot is not null)
{
    <Modal OnClose="() => _selectedSlot = null">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px;">
            <h2 class="font-ui" style="font-size: 18px; font-weight: 700; margin: 0; color: var(--text-primary);">🗄️ Chi tiết Ngăn @_selectedSlot.Id</h2>
            <button @onclick="() => _selectedSlot = null" style="background: none; border: none; color: var(--text-muted); font-size: 20px; cursor: pointer;">✕</button>
        </div>
        <div style="margin-bottom: 24px;">
            @if (_selectedSlot.Id.StartsWith("C"))
            {
                <div style="margin-bottom: 16px; padding: 12px; border-radius: 8px; background-color: rgba(239, 68, 68, 0.15); border: 1px solid rgba(239, 68, 68, 0.25); color: #F87171; font-size: 13px;" class="font-ui">
                    ⚠️ <strong>Lưu ý Khu C:</strong> Ngăn tủ bảo quản đặc biệt (Lạnh sâu -5°C) dành riêng cho các trường hợp thi thể không nguyên vẹn hoặc yêu cầu vệ sinh dịch tễ nghiêm ngặt.
                </div>
            }
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
                <div><div class="font-ui" style="font-size: 11px; color: var(--text-muted); text-transform: uppercase;">Ngăn</div><div class="font-ui" style="font-size: 14px; color: var(--text-primary);">@_selectedSlot.Id</div></div>
                <div><div class="font-ui" style="font-size: 11px; color: var(--text-muted); text-transform: uppercase;">Trạng thái</div><div class="font-ui" style="font-size: 14px; color: @(_selectedSlot.Status == Models.SlotStatus.Occupied ? "#EF4444" : _selectedSlot.Status == Models.SlotStatus.Empty ? "#10B981" : _selectedSlot.Status == Models.SlotStatus.Cleaning ? "#F59E0B" : "#6366F1");">@_selectedSlot.Status</div></div>
                <div><div class="font-ui" style="font-size: 11px; color: var(--text-muted); text-transform: uppercase;">Nhiệt độ</div><div class="font-ui" style="font-size: 14px; color: @(_selectedSlot.Temp > 6 ? "var(--danger)" : _selectedSlot.Temp < 0 ? "var(--ice)" : "var(--success)");">@_selectedSlot.Temp.ToString("F1")°C</div></div>
                <div><div class="font-ui" style="font-size: 11px; color: var(--text-muted); text-transform: uppercase;">Thời gian lưu</div><div class="font-ui" style="font-size: 14px; color: var(--text-primary);">@_selectedSlot.DaysStored ngày</div></div>
                @if (_selectedSlot.Status == Models.SlotStatus.Occupied)
                {
                    <div style="grid-column: 1/-1;"><div class="font-ui" style="font-size: 11px; color: var(--text-muted); text-transform: uppercase;">Thi thể đang lưu trữ</div><div class="font-ui" style="font-size: 14px; color: var(--text-primary); font-weight: 600;">@(_selectedSlot.CorpseName ?? "Không rõ tên")</div></div>
                }
            </div>
        </div>
        <div style="display: flex; gap: 8px; flex-wrap: wrap;">
            <button @onclick="ViewCorpseDetails" 
                    disabled="@(_selectedSlot.Status != Models.SlotStatus.Occupied)" 
                    class="font-ui" 
                    style="padding: 8px 16px; border-radius: 8px; font-size: 12px; cursor: pointer; border: 1px solid var(--ice); color: var(--ice); background: transparent; opacity: @(_selectedSlot.Status != Models.SlotStatus.Occupied ? "0.5" : "1"); cursor: @(_selectedSlot.Status != Models.SlotStatus.Occupied ? "not-allowed" : "pointer");">👁️ Xem thi thể</button>

            <button @onclick="StartHandover" 
                    disabled="@(_selectedSlot.Status != Models.SlotStatus.Occupied)" 
                    class="font-ui" 
                    style="padding: 8px 16px; border-radius: 8px; font-size: 12px; cursor: pointer; border: 1px solid var(--success); color: var(--success); background: transparent; opacity: @(_selectedSlot.Status != Models.SlotStatus.Occupied ? "0.5" : "1"); cursor: @(_selectedSlot.Status != Models.SlotStatus.Occupied ? "not-allowed" : "pointer");">📋 Bàn giao</button>
            
            <button @onclick="() => _isTransferring = !_isTransferring" 
                    disabled="@(_selectedSlot.Status != Models.SlotStatus.Occupied)" 
                    class="font-ui" 
                    style="padding: 8px 16px; border-radius: 8px; font-size: 12px; cursor: pointer; border: 1px solid var(--candle); color: var(--candle); background: transparent; opacity: @(_selectedSlot.Status != Models.SlotStatus.Occupied ? "0.5" : "1"); cursor: @(_selectedSlot.Status != Models.SlotStatus.Occupied ? "not-allowed" : "pointer");">🔄 Chuyển ngăn</button>
            
            <button @onclick="ToggleCleaning" 
                    disabled="@(_selectedSlot.Status == Models.SlotStatus.Occupied)" 
                    class="font-ui" 
                    style="padding: 8px 16px; border-radius: 8px; font-size: 12px; cursor: pointer; border: 1px solid var(--candle-deep); color: var(--candle-deep); background: transparent; opacity: @(_selectedSlot.Status == Models.SlotStatus.Occupied ? "0.5" : "1"); cursor: @(_selectedSlot.Status == Models.SlotStatus.Occupied ? "not-allowed" : "pointer");">
                @(_selectedSlot.Status == Models.SlotStatus.Cleaning ? "🧹 Hoàn tất vệ sinh" : "🧹 Đánh dấu vệ sinh")
            </button>
            
            <button @onclick="ToggleMaintenance" 
                    disabled="@(_selectedSlot.Status == Models.SlotStatus.Occupied)" 
                    class="font-ui" 
                    style="padding: 8px 16px; border-radius: 8px; font-size: 12px; cursor: pointer; border: 1px solid var(--info); color: var(--info); background: transparent; opacity: @(_selectedSlot.Status == Models.SlotStatus.Occupied ? "0.5" : "1"); cursor: @(_selectedSlot.Status == Models.SlotStatus.Occupied ? "not-allowed" : "pointer");">
                @(_selectedSlot.Status == Models.SlotStatus.Maintenance ? "🔧 Hoàn tất bảo trì" : "🔧 Bảo trì")
            </button>
        </div>

        @if (_isTransferring)
        {
            <div style="margin-top: 16px; padding: 12px; border-radius: 8px; background-color: var(--bg-elevated); border: 1px solid var(--border-primary);">
                <div class="font-ui" style="font-size: 12px; color: var(--text-muted); margin-bottom: 8px; font-weight: 500;">Chọn ngăn trống để di chuyển thi thể:</div>
                <div style="display: flex; gap: 8px;">
                    <select class="filter-select" @bind="_targetSlotId" style="flex: 1; padding: 6px; border-radius: 6px; border: 1px solid var(--border-primary); background: var(--bg-card); color: var(--text-primary); outline: none;">
                        <option value="">-- Chọn ngăn trống --</option>
                        @foreach (var slot in GetEmptySlots())
                        {
                            <option value="@slot.Id">@slot.Id (@slot.Zone)</option>
                        }
                    </select>
                    <button @onclick="ConfirmTransfer" class="font-ui" style="padding: 6px 12px; border-radius: 6px; background: var(--success); color: white; border: none; cursor: pointer; font-weight: 600;">Xác nhận</button>
                    <button @onclick="CancelTransfer" class="font-ui" style="padding: 6px 12px; border-radius: 6px; background: transparent; color: var(--text-muted); border: 1px solid var(--border-primary); cursor: pointer;">Hủy</button>
                </div>
            </div>
        }
    </Modal>
}

<ConfirmDialog IsVisible="@_showHandoverConfirm"
               Title="Xác nhận bàn giao thi thể"
               Message="@($"Xác nhận bàn giao thi thể {_handoverCorpse?.Name} ({_handoverCorpse?.CaseId}) cho thân nhân và giải phóng ngăn tủ {_selectedSlot?.Id}?")"
               ConfirmText="Xác nhận bàn giao"
               CancelText="Hủy"
               Type="success"
               OnConfirm="ConfirmHandover"
               OnCancel="() => _showHandoverConfirm = false" />

@if (_showToast)
{
    <Toast Message="@_toastMessage" Type="success" />
}

@code {
    private bool _showTemp = true;
    private double _zoneATemp = 2.3;
    private double _zoneBTemp = 3.8;
    private double _zoneCTemp = -4.8;
    private Models.StorageSlot? _selectedSlot;

    private List<Models.StorageSlot> _zoneASlots = new();
    private List<Models.StorageSlot> _zoneBSlots = new();
    private List<Models.StorageSlot> _zoneCSlots = new();

    private bool _isTransferring = false;
    private string _targetSlotId = "";
    private bool _showHandoverConfirm = false;
    private Models.Corpse? _handoverCorpse;
    private bool _showToast = false;
    private string _toastMessage = "";

    protected override async Task OnInitializedAsync()
    {
        InitDefaultSlots();
        await LoadOccupiedSlotsFromSupabaseAsync();
    }

    private void InitDefaultSlots()
    {
        _zoneASlots = Enumerable.Range(1, 10).Select(i => new Models.StorageSlot
        {
            Id = $"A-{i:D2}", Zone = "A",
            Status = Models.SlotStatus.Empty,
            Temp = 1.8 + (i * 0.3),
            CorpseName = null,
            DaysStored = 0,
            LastUpdate = $"{DateTime.Now:HH:mm}",
        }).ToList();

        _zoneBSlots = Enumerable.Range(1, 10).Select(i => new Models.StorageSlot
        {
            Id = $"B-{i:D2}", Zone = "B",
            Status = Models.SlotStatus.Empty,
            Temp = 3.0 + (i * 0.4),
            CorpseName = null,
            DaysStored = 0,
            LastUpdate = $"{DateTime.Now:HH:mm}",
        }).ToList();

        _zoneCSlots = Enumerable.Range(1, 5).Select(i => new Models.StorageSlot
        {
            Id = $"C-{i:D2}", Zone = "C",
            Status = Models.SlotStatus.Empty,
            Temp = -5.4 + (i * 0.2),
            CorpseName = null,
            DaysStored = 0,
            LastUpdate = $"{DateTime.Now:HH:mm}",
        }).ToList();
    }

    private async Task LoadOccupiedSlotsFromSupabaseAsync()
    {
        try
        {
            var response = await Supabase.From<Models.Corpse>().Get();
            var corpses = response.Models;

            // Reset local states to empty first (to allow fresh load)
            foreach (var slot in _zoneASlots.Concat(_zoneBSlots).Concat(_zoneCSlots))
            {
                if (slot.Status == Models.SlotStatus.Occupied)
                {
                    slot.Status = Models.SlotStatus.Empty;
                    slot.CorpseName = null;
                    slot.DaysStored = 0;
                }
            }

            foreach (var corpse in corpses)
            {
                if (string.IsNullOrEmpty(corpse.StorageSlot) || corpse.Status == "Bàn giao") continue;

                var slot = GetSlotById(corpse.StorageSlot);
                if (slot != null)
                {
                    slot.Status = Models.SlotStatus.Occupied;
                    slot.CorpseName = corpse.Name;
                    slot.DaysStored = corpse.DaysStored;
                    if (corpse.Temp.HasValue)
                    {
                        slot.Temp = corpse.Temp.Value;
                    }
                    slot.LastUpdate = $"{DateTime.Now:HH:mm}";
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine("Error loading corpses: " + ex.Message);
        }
    }

    private Models.StorageSlot? GetSlotById(string id)
    {
        return _zoneASlots.FirstOrDefault(s => s.Id == id) 
            ?? _zoneBSlots.FirstOrDefault(s => s.Id == id) 
            ?? _zoneCSlots.FirstOrDefault(s => s.Id == id);
    }

    private List<Models.StorageSlot> GetEmptySlots()
    {
        return _zoneASlots.Concat(_zoneBSlots).Concat(_zoneCSlots)
            .Where(s => s.Status == Models.SlotStatus.Empty)
            .ToList();
    }

    private async Task ViewCorpseDetails()
    {
        if (_selectedSlot == null || string.IsNullOrEmpty(_selectedSlot.CorpseName)) return;
        try
        {
            var response = await Supabase.From<Models.Corpse>()
                .Where(c => c.StorageSlot == _selectedSlot.Id)
                .Get();
            var corpse = response.Models.FirstOrDefault();
            if (corpse != null)
            {
                Navigation.NavigateTo($"/admin/corpses/{corpse.Id}");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine("Error finding corpse: " + ex.Message);
        }
    }

    private async Task StartHandover()
    {
        if (_selectedSlot == null || string.IsNullOrEmpty(_selectedSlot.CorpseName)) return;
        try
        {
            var response = await Supabase.From<Models.Corpse>()
                .Where(c => c.StorageSlot == _selectedSlot.Id)
                .Get();
            _handoverCorpse = response.Models.FirstOrDefault();
            if (_handoverCorpse != null)
            {
                _showHandoverConfirm = true;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine("Error finding corpse for handover: " + ex.Message);
        }
    }

    private async Task ConfirmHandover()
    {
        _showHandoverConfirm = false;
        if (_handoverCorpse != null && _selectedSlot != null)
        {
            try
            {
                var corpseName = _handoverCorpse.Name;
                var caseId = _handoverCorpse.CaseId;

                _handoverCorpse.Status = "Bàn giao";
                _handoverCorpse.StorageSlot = null;
                _handoverCorpse.StorageUnit = null;
                _handoverCorpse.Temp = null;
                
                _handoverCorpse.History.Add(new HistoryEntry
                {
                    Status = "Bàn giao",
                    Timestamp = DateTime.Now.ToString("dd-MM-yyyy HH:mm"),
                    By = "Hệ thống",
                    Detail = $"Bàn giao thi thể cho gia đình, giải phóng ngăn {_selectedSlot.Id}"
                });

                await Supabase.From<Models.Corpse>().Update(_handoverCorpse);

                _selectedSlot.Status = Models.SlotStatus.Empty;
                _selectedSlot.CorpseName = null;
                _selectedSlot.DaysStored = 0;
                _selectedSlot.LastUpdate = $"{DateTime.Now:HH:mm}";

                // Show success toast
                _toastMessage = $"Đã bàn giao thi thể {corpseName} ({caseId}) thành công!";
                _showToast = true;

                _selectedSlot = null;
                _handoverCorpse = null;
                StateHasChanged();

                await Task.Delay(3000);
                _showToast = false;
                StateHasChanged();
            }
            catch (Exception ex)
            {
                Console.WriteLine("Error during handover: " + ex.Message);
            }
        }
    }

    private void CancelTransfer()
    {
        _isTransferring = false;
        _targetSlotId = "";
    }

    private async Task ConfirmTransfer()
    {
        if (string.IsNullOrEmpty(_targetSlotId) || _selectedSlot == null) return;
        try
        {
            var response = await Supabase.From<Models.Corpse>()
                .Where(c => c.StorageSlot == _selectedSlot.Id)
                .Get();
            var corpse = response.Models.FirstOrDefault();
            if (corpse != null)
            {
                // Update corpse slot in database
                corpse.StorageSlot = _targetSlotId;
                corpse.StorageUnit = _targetSlotId.StartsWith("A") ? "Cold Room A" : _targetSlotId.StartsWith("B") ? "Cold Room B" : "Cold Room C";
                corpse.Temp = _targetSlotId.StartsWith("C") ? -5.5 : 2.5;

                // Add history record
                corpse.History.Add(new HistoryEntry
                {
                    Status = "Lưu kho",
                    Timestamp = DateTime.Now.ToString("dd-MM-yyyy HH:mm"),
                    By = "Hệ thống",
                    Detail = $"Di chuyển từ ngăn {_selectedSlot.Id} sang ngăn {_targetSlotId}"
                });

                await Supabase.From<Models.Corpse>().Update(corpse);

                // Update UI states
                var targetSlot = GetSlotById(_targetSlotId);
                if (targetSlot != null)
                {
                    targetSlot.Status = Models.SlotStatus.Occupied;
                    targetSlot.CorpseName = corpse.Name;
                    targetSlot.DaysStored = corpse.DaysStored;
                    targetSlot.Temp = corpse.Temp ?? targetSlot.Temp;
                    targetSlot.LastUpdate = $"{DateTime.Now:HH:mm}";
                }

                _selectedSlot.Status = Models.SlotStatus.Empty;
                _selectedSlot.CorpseName = null;
                _selectedSlot.DaysStored = 0;
                _selectedSlot.LastUpdate = $"{DateTime.Now:HH:mm}";

                _isTransferring = false;
                _selectedSlot = null; // Close modal
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine("Error transferring slot: " + ex.Message);
        }
    }

    private void ToggleCleaning()
    {
        if (_selectedSlot == null || _selectedSlot.Status == Models.SlotStatus.Occupied) return;

        if (_selectedSlot.Status == Models.SlotStatus.Cleaning)
        {
            _selectedSlot.Status = Models.SlotStatus.Empty;
        }
        else
        {
            _selectedSlot.Status = Models.SlotStatus.Cleaning;
        }
        _selectedSlot.LastUpdate = $"{DateTime.Now:HH:mm}";
        _selectedSlot = null; // Close modal
    }

    private void ToggleMaintenance()
    {
        if (_selectedSlot == null || _selectedSlot.Status == Models.SlotStatus.Occupied) return;

        if (_selectedSlot.Status == Models.SlotStatus.Maintenance)
        {
            _selectedSlot.Status = Models.SlotStatus.Empty;
        }
        else
        {
            _selectedSlot.Status = Models.SlotStatus.Maintenance;
        }
        _selectedSlot.LastUpdate = $"{DateTime.Now:HH:mm}";
        _selectedSlot = null; // Close modal
    }

    private void NavToTemperature() => Navigation.NavigateTo("/admin/temperature");
    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender)
        {
            TourService.TriggerStateChangeFromPage();
        }
    }

    private void SlotClicked(Models.StorageSlot slot)
    {
        _selectedSlot = slot;
        _isTransferring = false;
        _targetSlotId = "";
    }
}
