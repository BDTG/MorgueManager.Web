    private async Task SaveNewCorpse()
    {
        if (string.IsNullOrWhiteSpace(_newName)) return;

        var dto = new CreateCorpseDto
        {
            Name = _newName,
            Cccd = string.IsNullOrWhiteSpace(_newCccd) ? "000000000000" : _newCccd,
            Gender = _newGender,
            BirthDate = _newBirthDate.ToString("yyyy-MM-dd"),
            Age = DateTime.Now.Year - _newBirthDate.Year,
            CauseOfDeath = _newCause,
            DateOfDeath = _newDateOfDeath.ToString("yyyy-MM-dd"),
            Status = string.IsNullOrEmpty(_newSlot) ? "Tiếp nhận" : "Lưu kho",
            StorageSlot = string.IsNullOrEmpty(_newSlot) ? null : _newSlot,
            StorageUnit = string.IsNullOrEmpty(_newSlot) ? null : (_newSlot.StartsWith("A") ? "Cold Room A" : _newSlot.StartsWith("B") ? "Cold Room B" : "Cold Room C"),
            Temp = string.IsNullOrEmpty(_newSlot) ? null : (_newSlot.StartsWith("C") ? -5.5 : 2.5),
            Notes = _newNotes,
            Biohazard = BiohazardLevel.None,
            NextOfKin = new NextOfKinDto
            {
                Name = "Thân nhân " + _newName,
                Phone = _newNokPhone,
                Relationship = "Người thân"
            }
        };

        try
        {
            await EnsureAuthorizedAsync();
            await ApiService.PostAsync<object>("api/corpses", dto);
            _showCreateModal = false;
            await LoadCorpsesAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine("Error saving new corpse: " + ex.Message);
            _showCreateModal = false;
        }
    }

