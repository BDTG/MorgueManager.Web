        _newBirthDate = DateTime.Now.AddYears(-50);
        _newCccd = "";
        _newNokPhone = "";
        _newCause = "";
        _newDateOfDeath = DateTime.Now;
        _newDateAdmitted = DateTime.Now;
        _newIsNonIntact = false;
        _newNotes = "";
        _newSlot = "";
        _showCreateModal = true;
    }

    private void OnNonIntactChanged()
    {
        if (_newIsNonIntact)
        {
            _newNotes = "[Thi thể không nguyên vẹn - Bảo quản đặc biệt tại Khu C]";
            var firstCSlot = _availableSlots.FirstOrDefault(s => s.StartsWith("C"));
            if (!string.IsNullOrEmpty(firstCSlot))
            {
                _newSlot = firstCSlot;
            }
        }
        else
        {
            _newNotes = "";
            _newSlot = "";
        }
    }

    private IEnumerable<string> GetAvailableSlotsForNewCorpse()
    {
        if (_newIsNonIntact)
        {
            return _availableSlots.Where(s => s.StartsWith("C"));
        }
        else
        {
            return _availableSlots.Where(s => !s.StartsWith("C"));
        }
    }
