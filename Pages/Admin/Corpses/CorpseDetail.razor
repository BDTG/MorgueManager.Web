@page "/admin/corpses/{Id:int}"
@layout Components.Layout.AdminLayout
@inject NavigationManager Navigation
@inject MorgueManager.Web.Services.ApiService ApiService
@inject HttpClient Http
@inject IJSRuntime JS

<div>
    <div style="display: flex; flex-wrap: wrap; justify-content: space-between; align-items: center; gap: 16px; margin-bottom: 24px;">
        <div>
            <div class="font-ui" style="font-size: 12px; color: var(--text-muted); margin-bottom: 4px;">
                <a href="/admin/corpses" style="color: var(--text-muted); text-decoration: none;">Dashboard</a> / Quản lý Thi thể / Chi tiết #@Id
            </div>
            <h1 class="font-ui" style="font-size: 22px; font-weight: 700; margin: 0; color: var(--text-primary);">Chi tiết thi thể</h1>
        </div>
        <div style="display: flex; gap: 8px; flex-wrap: wrap;">
            <button @onclick="NavBack" class="font-ui" style="padding: 8px 16px; border-radius: 8px; font-size: 12px; cursor: pointer; border: 1px solid var(--border-primary); color: var(--text-secondary); background: transparent;">← Quay lại</button>
            @if (_userRole == "Admin" || _userRole == "Manager")
            {
                <button class="font-ui" style="padding: 8px 16px; border-radius: 8px; font-size: 12px; cursor: pointer; border: 1px solid var(--candle); color: var(--candle); background: transparent;">✏️ Sửa</button>
                <button class="font-ui" style="padding: 8px 16px; border-radius: 8px; font-size: 12px; cursor: pointer; border: none; background: var(--success); color: white; font-weight: 600;">📋 Bàn giao</button>
            }
            <button class="font-ui" style="padding: 8px 16px; border-radius: 8px; font-size: 12px; cursor: pointer; border: 1px solid var(--ice); color: var(--ice); background: transparent;">🖨️ In hồ sơ</button>
            @if (_userRole == "Admin")
            {
                <button class="font-ui" style="padding: 8px 16px; border-radius: 8px; font-size: 12px; cursor: pointer; border: 1px solid var(--danger); color: var(--danger); background: transparent;">🗑️ Xóa</button>
            }
        </div>
    </div>

    @if (_loading)
    {
        <div class="font-ui" style="padding: 40px; text-align: center; color: var(--text-muted);">
            Đang tải thông tin hồ sơ...
        </div>
    }
    else if (_corpse == null)
    {
        <div class="font-ui" style="padding: 40px; text-align: center; color: var(--danger);">
            Không tìm thấy hồ sơ thi thể #@Id.
        </div>
    }
    else
    {
        <div style="display: grid; grid-template-columns: 1fr 2.5fr; gap: 24px;">
            <!-- Profile Card -->
            <div style="padding: 24px; border-radius: 12px; background-color: var(--bg-card); border: 1px solid var(--border-primary); text-align: center;">
                <div style="width: 80px; height: 80px; border-radius: 50%; background-color: var(--bg-elevated); margin: 0 auto 16px; display: flex; align-items: center; justify-content: center; font-size: 36px;">👤</div>
                <h2 class="font-ui" style="font-size: 18px; font-weight: 600; margin: 0 0 4px; color: var(--text-primary);">@_corpse.Name</h2>
                <StatusBadge Status="@_corpse.Status" />

                @if (!string.IsNullOrEmpty(GetRetentionWarning()))
                {
                    <div style="margin-top: 12px; padding: 8px; border-radius: 6px; background-color: rgba(0,0,0,0.2); border: 1px solid @GetRetentionWarningColor(); color: @GetRetentionWarningColor(); font-size: 11px; font-weight: 600;">
                        @GetRetentionWarning()
                    </div>
                }

                <div style="margin: 16px 0;">
                    <div class="font-ui" style="font-size: 12px; color: var(--text-muted);">Mã thi thể</div>
                    <div class="font-ui" style="font-family: monospace; font-size: 14px; color: var(--text-primary);">@_corpse.CaseId</div>
                </div>
                <div style="margin: 16px 0;">
                    <div class="font-ui" style="font-size: 12px; color: var(--text-muted);">Ngăn tủ</div>
                    <a href="/admin/storages" style="font-family: 'Inter', sans-serif; font-size: 14px; color: var(--ice); text-decoration: none;">@(_corpse.StorageSlot ?? "—")</a>
                </div>
                <div style="margin: 16px 0;">
                    <div class="font-ui" style="font-size: 12px; color: var(--text-muted);">Nhiệt độ ngăn</div>
                    <div class="font-ui" style="font-size: 20px; font-weight: 600; color: var(--success);">@(_corpse.Temp?.ToString("0.0") ?? "—")°C ✅</div>
                </div>
                <div style="margin: 24px auto; width: 120px; height: 120px; background-color: white; border-radius: 8px; display: flex; align-items: center; justify-content: center; font-size: 12px; color: #333;">[QR Code]</div>
                <button class="font-ui" style="width: 100%; padding: 8px; border: 1px solid var(--border-primary); border-radius: 8px; background: transparent; color: var(--text-secondary); cursor: pointer; font-size: 12px; margin-bottom: 8px;">📥 Tải QR Code</button>
                <button class="font-ui" style="width: 100%; padding: 8px; border: 1px solid var(--border-primary); border-radius: 8px; background: transparent; color: var(--text-secondary); cursor: pointer; font-size: 12px;">🔗 Sao chép link</button>
            </div>

            <!-- Tabs -->
            <div>
                <div class="tab-bar">
                    <button class="tab-item @(_activeTab == "info" ? "active" : "")" @onclick="SetTabInfo">Thông tin</button>
                    <button class="tab-item @(_activeTab == "belongings" ? "active" : "")" @onclick="SetTabBelongings">Tư trang</button>
                    <button class="tab-item @(_activeTab == "history" ? "active" : "")" @onclick="SetTabHistory">Lịch sử</button>
                    <button class="tab-item @(_activeTab == "documents" ? "active" : "")" @onclick="SetTabDocuments">Tài liệu</button>
                </div>

                @if (_activeTab == "info")
                {
                    <div style="padding: 24px; border-radius: 12px; background-color: var(--bg-card); border: 1px solid var(--border-primary);">
                        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
                            <div><div class="font-ui" style="font-size: 11px; color: var(--text-muted); text-transform: uppercase;">Họ tên</div><div class="font-ui" style="font-size: 14px; color: var(--text-primary);">@_corpse.Name</div></div>
                            <div><div class="font-ui" style="font-size: 11px; color: var(--text-muted); text-transform: uppercase;">Giới tính</div><div class="font-ui" style="font-size: 14px; color: var(--text-primary);">@_corpse.Gender</div></div>
                            <div><div class="font-ui" style="font-size: 11px; color: var(--text-muted); text-transform: uppercase;">Ngày sinh</div><div class="font-ui" style="font-size: 14px; color: var(--text-primary);">@_corpse.BirthDate</div></div>
                            <div><div class="font-ui" style="font-size: 11px; color: var(--text-muted); text-transform: uppercase;">Nhóm bệnh truyền nhiễm</div><div class="font-ui" style="font-size: 14px; color: @(_corpse.IsInfectious ? "var(--danger)" : "var(--text-primary)"); font-weight: @(_corpse.IsInfectious ? "bold" : "normal");">@(_corpse.IsInfectious ? _corpse.InfectiousGroup : "Không")</div></div>
                            <div><div class="font-ui" style="font-size: 11px; color: var(--text-muted); text-transform: uppercase;">Chế độ lưu trữ</div><div class="font-ui" style="font-size: 14px; color: var(--text-primary);">@(_corpse.RequiresDeepFreeze ? "Đông sâu (-16°C)" : "Lạnh thường (2-4°C)")</div></div>
                            <div><div class="font-ui" style="font-size: 11px; color: var(--text-muted); text-transform: uppercase;">Số Giấy chứng tử</div><div class="font-ui" style="font-size: 14px; color: var(--text-primary);">@(_corpse.DeathCertificateId == "" ? "Chưa cập nhật" : _corpse.DeathCertificateId)</div></div>
                            <div><div class="font-ui" style="font-size: 11px; color: var(--text-muted); text-transform: uppercase;">Pháp lý</div><div class="font-ui" style="font-size: 14px; color: var(--text-primary);">@(_corpse.IsUnidentified ? "Vô danh" : "Đã định danh")</div></div>
                            <div style="grid-column: 1/-1;"><div class="font-ui" style="font-size: 11px; color: var(--text-muted); text-transform: uppercase;">Nguyên nhân tử vong</div><div class="font-ui" style="font-size: 14px; color: var(--text-primary);">@_corpse.CauseOfDeath</div></div>
                            <div><div class="font-ui" style="font-size: 11px; color: var(--text-muted); text-transform: uppercase;">Ngày tử vong</div><div class="font-ui" style="font-size: 14px; color: var(--text-primary);">@_corpse.DateOfDeath</div></div>
                            <div><div class="font-ui" style="font-size: 11px; color: var(--text-muted); text-transform: uppercase;">Ngày tiếp nhận</div><div class="font-ui" style="font-size: 14px; color: var(--text-primary);">@_corpse.DateAdmitted</div></div>
                            <div><div class="font-ui" style="font-size: 11px; color: var(--text-muted); text-transform: uppercase;">Thân nhân</div><div class="font-ui" style="font-size: 14px; color: var(--text-primary);">@_corpse.NextOfKin.Name</div></div>
                            <div><div class="font-ui" style="font-size: 11px; color: var(--text-muted); text-transform: uppercase;">SĐT thân nhân</div><div class="font-ui" style="font-size: 14px; color: var(--text-primary);">@_corpse.NextOfKin.Phone</div></div>
                            <div><div class="font-ui" style="font-size: 11px; color: var(--text-muted); text-transform: uppercase;">Quan hệ</div><div class="font-ui" style="font-size: 14px; color: var(--text-primary);">@_corpse.NextOfKin.Relationship</div></div>
                        </div>
                    </div>
                }

                @if (_activeTab == "belongings")
                {
                    <div style="padding: 24px; border-radius: 12px; background-color: var(--bg-card); border: 1px solid var(--border-primary);">
                        <table class="data-table">
                            <thead><tr><th>#</th><th>Tên vật phẩm</th><th>Mô tả</th><th>Tình trạng</th></tr></thead>
                            <tbody>
                                @if (_corpse.Belongings != null && _corpse.Belongings.Count > 0)
                                {
                                    @foreach (var b in _corpse.Belongings)
                                    {
                                        <tr>
                                            <td>@b.Id</td><td>@b.Name</td><td>@b.Desc</td><td>@b.Condition</td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="4" style="text-align: center; color: var(--text-muted); padding: 12px;">Không có tư trang nào</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }

                @if (_activeTab == "history")
                {
                    <div style="padding: 24px; border-radius: 12px; background-color: var(--bg-card); border: 1px solid var(--border-primary);">
                        <div style="position: relative; padding-left: 24px;">
                            <div style="position: absolute; left: 8px; top: 0; bottom: 0; width: 2px; background-color: var(--border-primary);"></div>
                            @if (_corpse.History != null && _corpse.History.Count > 0)
                            {
                                @foreach (var h in _corpse.History)
                                {
                                    <div style="margin-bottom: 24px; position: relative;">
                                        <div style="position: absolute; left: -20px; top: 4px; width: 12px; height: 12px; border-radius: 50%; background-color: var(--ice);"></div>
                                        <div class="font-ui" style="font-weight: 500; color: var(--text-primary);">@h.Status — @h.Detail</div>
                                        <div class="font-ui" style="font-size: 12px; color: var(--text-muted);">@h.Timestamp — @h.By</div>
                                    </div>
                                }
                            }
                            else
                            {
                                <div style="margin-bottom: 24px; position: relative;">
                                    <div style="position: absolute; left: -20px; top: 4px; width: 12px; height: 12px; border-radius: 50%; background-color: var(--success);"></div>
                                    <div class="font-ui" style="font-weight: 500; color: var(--text-primary);">✅ Tiếp nhận</div>
                                    <div class="font-ui" style="font-size: 12px; color: var(--text-muted);">@_corpse.DateAdmitted — Hệ thống</div>
                                </div>
                            }
                        </div>
                    </div>
                }

                @if (_activeTab == "documents")
                {
                    <div style="padding: 24px; border-radius: 12px; background-color: var(--bg-card); border: 1px solid var(--border-primary);">
                        <div style="padding: 20px; border: 2px dashed var(--border-primary); border-radius: 12px; text-align: center; margin-bottom: 16px;">
                            <div class="font-ui" style="font-size: 12px; color: var(--text-muted);">Kéo thả file hoặc nhấp để tải lên</div>
                        </div>
                        @if (_corpse.Documents != null && _corpse.Documents.Count > 0)
                        {
                            @foreach (var d in _corpse.Documents)
                            {
                                <div style="display: flex; align-items: center; gap: 12px; padding: 12px; border: 1px solid var(--border-primary); border-radius: 8px; margin-bottom: 8px;">
                                    <span style="font-size: 24px;">📄</span>
                                    <div>
                                        <div class="font-ui" style="font-size: 13px; color: var(--text-primary);">@d.Name</div>
                                        <div class="font-ui" style="font-size: 11px; color: var(--text-muted);">@d.Size</div>
                                    </div>
                                    <div style="margin-left: auto; display: flex; gap: 8px;">
                                        <button class="font-ui" style="background: none; border: none; color: var(--ice); cursor: pointer; font-size: 12px;">📥</button>
                                        <button class="font-ui" style="background: none; border: none; color: var(--danger); cursor: pointer; font-size: 12px;">🗑️</button>
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <div style="display: flex; align-items: center; gap: 12px; padding: 12px; border: 1px solid var(--border-primary); border-radius: 8px;">
                                <span style="font-size: 24px;">📄</span>
                                <div>
                                    <div class="font-ui" style="font-size: 13px; color: var(--text-primary);">Giấy chứng tử.pdf</div>
                                    <div class="font-ui" style="font-size: 11px; color: var(--text-muted);">245 KB</div>
                                </div>
                                <div style="margin-left: auto; display: flex; gap: 8px;">
                                    <button class="font-ui" style="background: none; border: none; color: var(--ice); cursor: pointer; font-size: 12px;">📥</button>
                                    <button class="font-ui" style="background: none; border: none; color: var(--danger); cursor: pointer; font-size: 12px;">🗑️</button>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public int Id { get; set; }
    private string _activeTab = "info";
    private Models.Corpse? _corpse;
    private bool _loading = true;
    private string _userRole = "None";
    private string _userEmail = "";

    private async Task EnsureAuthorizedAsync()
    {
        try
        {
            var token = await JS.InvokeAsync<string>("localStorage.getItem", "morguemanager-token");
            if (!string.IsNullOrEmpty(token))
            {
                Http.DefaultRequestHeaders.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine("Error injecting auth header: " + ex.Message);
        }
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            await EnsureAuthorizedAsync();
            _userRole = await AdminAuthHelper.GetUserRoleAsync(JS);
            _userEmail = await AdminAuthHelper.GetUserEmailAsync(JS);

            if (_userRole == "None")
            {
                Navigation.NavigateTo("/login");
                return;
            }

            var dto = await ApiService.GetAsync<CorpseApiDto>($"api/corpses/{Id}");
            if (dto != null)
            {
                _corpse = new Models.Corpse
                {
                    Id = dto.Id,
                    CaseId = dto.CaseId,
                    Name = dto.Name,
                    Cccd = dto.Cccd,
                    Gender = dto.Gender,
                    BirthDate = dto.BirthDate,
                    Age = dto.Age,
                    CauseOfDeath = dto.CauseOfDeath,
                    DateOfDeath = dto.DateOfDeath,
                    DateAdmitted = dto.DateAdmitted,
                    Status = dto.Status,
                    StorageUnit = dto.StorageUnit,
                    StorageSlot = dto.StorageSlot,
                    Temp = dto.Temp,
                    DaysStored = dto.DaysStored,
                    Priority = dto.Priority,
                    Notes = dto.Notes,
                    NextOfKin = new Models.NextOfKinInfo
                    {
                        Name = dto.NextOfKin?.Name ?? "",
                        Phone = dto.NextOfKin?.Phone ?? "",
                        Relationship = dto.NextOfKin?.Relationship ?? ""
                    },
                    IsInfectious = dto.Biohazard == BiohazardLevel.Infectious || dto.Biohazard == BiohazardLevel.HighRisk,
                    InfectiousGroup = dto.Biohazard == BiohazardLevel.HighRisk ? "Nhóm nguy hiểm cao (Khu B)" : dto.Biohazard == BiohazardLevel.Infectious ? "Nhóm lây nhiễm" : "",
                    RequiresDeepFreeze = dto.StorageSlot != null && dto.StorageSlot.StartsWith("C"),
                    IsUnidentified = dto.Name.Contains("Vô danh") || dto.Notes.Contains("chưa xác định")
                };
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine("Error loading corpse details: " + ex.Message);
        }
        finally
        {
            _loading = false;
        }
    }

    private void SetTabInfo() { _activeTab = "info"; }
    private void SetTabBelongings() { _activeTab = "belongings"; }
    private void SetTabHistory() { _activeTab = "history"; }
    private void SetTabDocuments() { _activeTab = "documents"; }
    private void NavBack() => Navigation.NavigateTo("/admin/corpses");

    private string GetRetentionWarning()
    {
        if (_corpse == null || string.IsNullOrEmpty(_corpse.DateAdmitted)) return "";
        if (!DateTime.TryParseExact(_corpse.DateAdmitted, new[] { "dd-MM-yyyy", "yyyy-MM-dd", "dd/MM/yyyy", "MM/dd/yyyy" }, null, System.Globalization.DateTimeStyles.None, out var admitDate)) return "";

        var elapsedHours = (DateTime.Now - admitDate).TotalHours;
        var elapsedDays = (DateTime.Now - admitDate).TotalDays;

        if (_corpse.IsInfectious)
        {
            var remainingHours = 24 - elapsedHours;
            if (remainingHours < 0) return "⚠️ QUÁ HẠN LÂY NHIỄM (> 24H)!";
            return $"⚠️ Lây nhiễm: Còn {Math.Max(0, remainingHours):F1}h lưu giữ.";
        }

        if (_corpse.IsUnidentified)
        {
            var remainingDays = 30 - elapsedDays;
            if (remainingDays < 0) return "⚠️ QUÁ HẠN VÔ DANH (> 30 NGÀY)!";
            return $"ℹ️ Vô danh: Còn {Math.Max(0, remainingDays):F0} ngày tìm thân nhân.";
        }

        if (_corpse.RequiresDeepFreeze)
        {
            return "❄️ Lưu đông sâu: Chờ thủ tục pháp y.";
        }

        var normRemaining = 7 - elapsedDays;
        if (normRemaining < 0) return "⚠️ QUÁ HẠN THÔNG THƯỜNG (> 7 NGÀY)!";
        return $"ℹ️ Lưu trữ thông thường: Còn {Math.Max(0, normRemaining):F0} ngày.";
    }

    private string GetRetentionWarningColor()
    {
        var text = GetRetentionWarning();
        if (text.Contains("QUÁ HẠN") || text.Contains("Lây nhiễm")) return "var(--danger)";
        if (text.Contains("Vô danh")) return "orange";
        return "var(--ice)";
    }
}
