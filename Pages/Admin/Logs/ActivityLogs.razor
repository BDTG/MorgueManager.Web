@page "/admin/logs"
@layout Components.Layout.AdminLayout
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject HttpClient Http
@inject MorgueManager.Web.Services.ApiService ApiService

@if (!_isLoaded)
{
    <div class="font-ui" style="padding: 40px; text-align: center; color: var(--text-muted);">
        Đang tải nhật ký hoạt động...
    </div>
}
else if (_isAccessDenied)
{
    <div class="font-ui" style="padding: 40px; text-align: center; margin-top: 40px;">
        <div style="font-size: 48px; margin-bottom: 16px;">🚫</div>
        <h2 style="font-weight: 700; color: var(--text-primary); margin-bottom: 8px;">Quyền truy cập bị từ chối</h2>
        <p style="color: var(--text-secondary); margin-bottom: 24px;">Bạn không có quyền truy cập vào trang này. Chức năng này chỉ dành cho Quản lý hoặc Quản trị viên.</p>
        <button @onclick="NavToDashboard" style="padding: 8px 16px; border-radius: 8px; border: none; background: linear-gradient(135deg, #3B82F6, #2563EB); color: white; cursor: pointer; font-size: 13px; font-weight: 600;">Quay lại Dashboard</button>
    </div>
}
else
{
    <div>
        <div style="display: flex; flex-wrap: wrap; justify-content: space-between; align-items: center; gap: 16px; margin-bottom: 24px;">
            <div>
                <div class="font-ui" style="font-size: 12px; color: var(--text-muted); margin-bottom: 4px;">Dashboard / Nhật ký</div>
                <h1 class="font-ui" style="font-size: 22px; font-weight: 700; margin: 0; color: var(--text-primary);">📝 Nhật ký hoạt động</h1>
            </div>
            <div style="display: flex; gap: 8px;">
                <button class="font-ui" style="padding: 8px 16px; border-radius: 8px; font-size: 12px; cursor: pointer; border: 1px solid var(--success); color: var(--success); background: transparent;">📥 Xuất log</button>
                <button class="font-ui" style="padding: 8px 16px; border-radius: 8px; font-size: 12px; cursor: pointer; border: 1px solid var(--border-primary); color: var(--text-secondary); background: transparent;">🔄 Làm mới</button>
            </div>
        </div>

        <div class="filter-bar">
            <input class="filter-input" placeholder="🔍 Tìm theo nội dung..." />
            <select class="filter-select">
                <option value="">Người thực hiện</option>
                <option>Nguyễn Thị B</option>
                <option>Trần Văn C</option>
                <option>Lê Thị D</option>
            </select>
            <select class="filter-select">
                <option value="">Loại hành động</option>
                <option>Tạo mới</option>
                <option>Cập nhật</option>
                <option>Xóa</option>
                <option>Đăng nhập</option>
                <option>🌡️ Thay đổi nhiệt độ</option>
            </select>
            <input type="date" class="filter-input" style="min-width: 140px;" />
            <button class="font-ui" style="padding: 8px 12px; border: none; background: none; color: var(--text-muted); cursor: pointer; font-size: 12px;">🔄 Xóa bộ lọc</button>
        </div>

        <div style="border-radius: 12px; border: 1px solid var(--border-primary); overflow: hidden; background-color: var(--bg-card);">
            <table class="data-table">
                <thead><tr><th>#</th><th>Thời gian</th><th>Người thực hiện</th><th>Hành động</th><th>Chi tiết</th><th>Trang liên quan</th></tr></thead>
                <tbody>
                    @foreach (var log in _logs)
                    {
                        <tr>
                            <td style="font-size: 12px; color: var(--text-muted);">@log.Id</td>
                            <td style="font-family: monospace; font-size: 12px;">@log.Time</td>
                            <td style="font-size: 13px;">@log.User</td>
                            <td><span class="badge-pill" style="background-color: @(log.BadgeBg); color: @(log.BadgeText);">@log.Action</span></td>
                            <td style="font-size: 13px; max-width: 300px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">@log.Detail</td>
                            <td><a href="@log.Link" class="font-ui" style="font-size: 12px; color: var(--ice); text-decoration: none;">@log.LinkText</a></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div style="display: flex; justify-content: space-between; align-items: center; margin-top: 16px;">
            <div class="font-ui" style="font-size: 13px; color: var(--text-muted);">Hiển thị 1-25 / @_logs.Count kết quả</div>
            <div style="display: flex; gap: 4px;">
                <button class="font-ui" style="padding: 6px 12px; border: 1px solid var(--border-primary); background: var(--bg-card); border-radius: 6px; color: var(--text-secondary); cursor: pointer; font-size: 12px;">‹</button>
                <button class="font-ui" style="padding: 6px 12px; border: 1px solid var(--ice); background: var(--ice); border-radius: 6px; color: var(--bg-primary); cursor: pointer; font-size: 12px; font-weight: 600;">1</button>
                <button class="font-ui" style="padding: 6px 12px; border: 1px solid var(--border-primary); background: var(--bg-card); border-radius: 6px; color: var(--text-secondary); cursor: pointer; font-size: 12px;">2</button>
                <button class="font-ui" style="padding: 6px 12px; border: 1px solid var(--border-primary); background: var(--bg-card); border-radius: 6px; color: var(--text-secondary); cursor: pointer; font-size: 12px;">3</button>
                <button class="font-ui" style="padding: 6px 12px; border: 1px solid var(--border-primary); background: var(--bg-card); border-radius: 6px; color: var(--text-secondary); cursor: pointer; font-size: 12px;">›</button>
            </div>
        </div>
    </div>
}

@code {
    private List<LogEntry> _logs = new();
    private string _rawLogs = "";
    private string _userRole = "None";
    private string _userEmail = "";
    private bool _isLoaded = false;
    private bool _isAccessDenied = false;

    private async Task EnsureAuthorizedAsync()
    {
        try
        {
            var token = await JS.InvokeAsync<string>("localStorage.getItem", "morguemanager-token");
            if (!string.IsNullOrEmpty(token))
            {
                Http.DefaultRequestHeaders.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine("Error injecting auth header: " + ex.Message);
        }
    }

    protected override async Task OnInitializedAsync()
    {
        _userRole = await AdminAuthHelper.GetUserRoleAsync(JS);
        _userEmail = await AdminAuthHelper.GetUserEmailAsync(JS);

        if (_userRole == "None")
        {
            Navigation.NavigateTo("/login");
            return;
        }

        if (_userRole != "Admin" && _userRole != "Manager")
        {
            _isAccessDenied = true;
            _isLoaded = true;
            return;
        }

        await LoadLogsAsync();
        _isLoaded = true;
    }

    private void NavToDashboard() => Navigation.NavigateTo("/admin/dashboard");

    private async Task LoadLogsAsync()
    {
        try
        {
            await EnsureAuthorizedAsync();
            var res = await ApiService.GetAsync<LogsResponse>("api/logs");
            if (res != null && !string.IsNullOrEmpty(res.Logs))
            {
                _rawLogs = res.Logs;
                var lines = _rawLogs.Split('\n', StringSplitOptions.RemoveEmptyEntries);
                _logs = lines.Select((line, index) =>
                {
                    var time = DateTime.Now.ToString("dd/MM/yyyy") + " ";
                    var level = "INF";
                    var detail = line;
                    var user = "Hệ thống";

                    if (line.StartsWith("[") && line.Contains("]"))
                    {
                        var bracketIndex = line.IndexOf(']');
                        var meta = line.Substring(1, bracketIndex - 1);
                        detail = line.Substring(bracketIndex + 1).Trim();

                        var parts = meta.Split(' ');
                        if (parts.Length >= 1) time += parts[0];
                        if (parts.Length >= 2) level = parts[1];
                    }

                    var action = level switch
                    {
                        "INF" => "Thông tin",
                        "WRN" => "Cảnh báo",
                        "ERR" => "Lỗi",
                        "FTL" => "Lỗi chí mạng",
                        _ => level
                    };
                    var badgeBg = level switch
                    {
                        "INF" => "rgba(16,185,129,0.15)",
                        "WRN" => "rgba(245,158,11,0.15)",
                        "ERR" => "rgba(239,68,68,0.15)",
                        "FTL" => "rgba(239,68,68,0.25)",
                        _ => "var(--bg-elevated)"
                    };
                    var badgeText = level switch
                    {
                        "INF" => "var(--success)",
                        "WRN" => "var(--candle)",
                        "ERR" => "var(--danger)",
                        "FTL" => "var(--danger)",
                        _ => "var(--text-secondary)"
                    };

                    if (detail.Contains("Tiếp nhận"))
                    {
                        user = "Admin User";
                        action = "Tiếp nhận";
                    }
                    else if (detail.Contains("Bàn giao"))
                    {
                        user = "Admin User";
                        action = "Bàn giao";
                    }
                    else if (detail.Contains("Cập nhật"))
                    {
                        user = "Admin User";
                        action = "Cập nhật";
                    }

                    return new LogEntry
                    {
                        Id = index + 1,
                        Time = time,
                        User = user,
                        Action = action,
                        Detail = detail,
                        BadgeBg = badgeBg,
                        BadgeText = badgeText,
                        Link = detail.Contains("MC-") ? "/admin/corpses" : "",
                        LinkText = detail.Contains("MC-") ? "Xem danh sách" : ""
                    };
                }).OrderByDescending(x => x.Id).ToList();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine("Error loading logs: " + ex.Message);
        }
    }

    private class LogsResponse
    {
        public string Logs { get; set; } = "";
    }

    private class LogEntry
    {
        public int Id { get; set; }
        public string Time { get; set; } = "";
        public string User { get; set; } = "";
        public string Action { get; set; } = "";
        public string Detail { get; set; } = "";
        public string BadgeBg { get; set; } = "";
        public string BadgeText { get; set; } = "";
        public string Link { get; set; } = "";
        public string LinkText { get; set; } = "";
    }
}
