@page "/admin/temperature"
@layout Components.Layout.AdminLayout
@inject TemperatureSimulatorService TempService
@implements IDisposable

<div>
    <div style="display: flex; flex-wrap: wrap; justify-content: space-between; align-items: center; gap: 16px; margin-bottom: 24px;">
        <div>
            <div class="font-ui" style="font-size: 12px; color: var(--text-muted); margin-bottom: 4px;">Dashboard / Nhiệt độ</div>
            <h1 class="font-ui" style="font-size: 22px; font-weight: 700; margin: 0; color: var(--text-primary);">🌡️ Giám sát & Điều chỉnh Nhiệt độ</h1>
        </div>
        <div style="display: flex; gap: 8px;">
            <button class="font-ui" style="padding: 8px 16px; border-radius: 8px; font-size: 12px; cursor: pointer; border: 1px solid var(--success); color: var(--success); background: transparent;">📊 Xuất báo cáo</button>
            <button class="font-ui" style="padding: 8px 16px; border-radius: 8px; font-size: 12px; cursor: pointer; border: 1px solid var(--candle); color: var(--candle); background: transparent;">⚙️ Cài đặt ngưỡng</button>
            <button @onclick="Refresh" class="font-ui" style="padding: 8px 16px; border-radius: 8px; font-size: 12px; cursor: pointer; border: 1px solid var(--border-primary); color: var(--text-secondary); background: transparent;">🔄 Làm mới</button>
        </div>
    </div>

    <!-- Overview Cards -->
    <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; margin-bottom: 32px;">
        <!-- Zone A Gauge -->
        <div style="padding: 24px; border-radius: 12px; background-color: var(--bg-card); border: 1px solid var(--border-primary); text-align: center; display: flex; flex-direction: column; align-items: center;">
            <TempGauge CurrentTemp="@TempService.ZoneACurrent" TargetTemp="@TempService.ZoneATarget" />
            <div class="font-ui" style="margin-top: 12px;">❄️ Khu A — Tủ lạnh chính</div>
            <div style="margin-top: 4px;">
                <span class="badge-pill" style="background-color: rgba(16,185,129,0.15); color: var(--success);">✅ Bình thường</span>
            </div>
            <div class="font-ui" style="font-size: 11px; color: var(--text-muted); margin-top: 8px;">Min: 1.8°C | Max: 3.1°C</div>
            <button @onclick="ToggleZoneA" class="font-ui" style="margin-top: 16px; padding: 10px 20px; border: 1px solid var(--ice); border-radius: 8px; background: transparent; color: var(--ice); cursor: pointer; font-size: 13px;">
                🎛️ @GetZoneALabel() nhiệt độ Khu A
            </button>
        </div>

        <!-- Zone B Gauge -->
        <div style="padding: 24px; border-radius: 12px; background-color: var(--bg-card); border: 1px solid var(--border-primary); text-align: center; display: flex; flex-direction: column; align-items: center;">
            <TempGauge CurrentTemp="@TempService.ZoneBCurrent" TargetTemp="@TempService.ZoneBTarget" />
            <div class="font-ui" style="margin-top: 12px;">❄️ Khu B — Tủ lạnh phụ</div>
            <div style="margin-top: 4px;">
                <span class="badge-pill" style="background-color: rgba(245,158,11,0.15); color: var(--candle);">⚠️ Cảnh báo</span>
            </div>
            <div class="font-ui" style="font-size: 11px; color: var(--text-muted); margin-top: 8px;">Min: 2.5°C | Max: 5.2°C</div>
            <button @onclick="ToggleZoneB" class="font-ui" style="margin-top: 16px; padding: 10px 20px; border: 1px solid var(--candle); border-radius: 8px; background: transparent; color: var(--candle); cursor: pointer; font-size: 13px;">
                🎛️ @GetZoneBLabel() nhiệt độ Khu B
            </button>
        </div>

        <!-- Zone C Gauge -->
        <div style="padding: 24px; border-radius: 12px; background-color: var(--bg-card); border: 1px solid var(--border-primary); text-align: center; display: flex; flex-direction: column; align-items: center;">
            <TempGauge CurrentTemp="@_zoneCCurrent" TargetTemp="@_zoneCTarget" />
            <div class="font-ui" style="margin-top: 12px;">❄️ Khu C — Tủ cấp đông chuyên dụng</div>
            <div style="margin-top: 4px;">
                <span class="badge-pill" style="background-color: rgba(59,130,246,0.15); color: var(--ice);">✅ Lạnh sâu</span>
            </div>
            <div class="font-ui" style="font-size: 11px; color: var(--text-muted); margin-top: 8px;">Min: -6.0°C | Max: -4.0°C</div>
            <button @onclick="ToggleZoneC" class="font-ui" style="margin-top: 16px; padding: 10px 20px; border: 1px solid var(--ice); border-radius: 8px; background: transparent; color: var(--ice); cursor: pointer; font-size: 13px;">
                🎛️ @GetZoneCLabel() nhiệt độ Khu C
            </button>
        </div>
    </div>

    <!-- Control Panel -->
    @if (_expandedZone is not null)
    {
        var zone = _expandedZone;
        var currentTarget = zone == "A" ? TempService.ZoneATarget : zone == "B" ? TempService.ZoneBTarget : _zoneCTarget;
        var sliderBackground = zone == "C" ? "linear-gradient(to right, #2563EB, var(--ice))" : "linear-gradient(to right, var(--ice), var(--candle), var(--danger))";
        <div style="padding: 24px; border-radius: 12px; background-color: var(--bg-secondary); border: 1px solid var(--border-primary); margin-bottom: 32px;">
            <h3 class="font-ui" style="font-size: 16px; font-weight: 600; margin: 0 0 16px; color: var(--text-primary);">🎛️ Bảng điều khiển — Khu @zone</h3>
            <div style="margin-bottom: 16px;">
                <div style="display: flex; justify-content: space-between; margin-bottom: 8px;">
                    @if (zone == "C")
                    {
                        <span class="font-ui" style="font-size: 12px; color: var(--text-muted);">-12°C ❄️❄️</span>
                        <span class="font-ui" style="font-size: 16px; font-weight: 600; color: var(--ice);">@currentTarget.ToString("F1")°C</span>
                        <span class="font-ui" style="font-size: 12px; color: var(--text-muted);">0°C ❄️</span>
                    }
                    else
                    {
                        <span class="font-ui" style="font-size: 12px; color: var(--text-muted);">0°C ❄️</span>
                        <span class="font-ui" style="font-size: 16px; font-weight: 600; color: var(--ice);">@currentTarget.ToString("F1")°C</span>
                        <span class="font-ui" style="font-size: 12px; color: var(--text-muted);">8°C 🔥</span>
                    }
                </div>
                <input type="range" 
                       min="@(zone == "C" ? -12 : 0)" 
                       max="@(zone == "C" ? 0 : 8)" 
                       step="0.5" 
                       value="@currentTarget"
                       @onchange="OnSliderChange"
                       style="width: 100%; height: 6px; border-radius: 3px; background: @sliderBackground;" />
            </div>
            <div style="display: flex; gap: 8px; margin-bottom: 16px;">
                @if (zone == "C")
                {
                    @foreach (var preset in new[] { -10.0, -8.0, -5.0, -2.0 })
                    {
                        <button @onclick="() => StartSetTarget(zone, preset)"
                                class="font-ui" style="@GetPresetButtonStyle(zone, preset, currentTarget)">@preset°C</button>
                    }
                }
                else
                {
                    @foreach (var preset in new[] { 1.0, 2.0, 3.0, 4.0 })
                    {
                        <button @onclick="() => StartSetTarget(zone, preset)"
                                class="font-ui" style="@GetPresetButtonStyle(zone, preset, currentTarget)">@preset°C</button>
                    }
                }
            </div>
            <div style="display: flex; gap: 8px;">
                <button @onclick="() => StartSetTarget(zone, currentTarget)" class="font-ui" style="padding: 10px 24px; border: none; border-radius: 8px; background: var(--success); color: white; cursor: pointer; font-size: 13px; font-weight: 600;">✅ Áp dụng</button>
                <button @onclick="() => StartResetZoneTarget(zone)" class="font-ui" style="padding: 10px 24px; border: 1px solid var(--border-primary); border-radius: 8px; background: transparent; color: var(--text-secondary); cursor: pointer; font-size: 13px;">
                    ↩️ Đặt lại @(zone == "C" ? "-5°C" : "2°C")
                </button>
            </div>
            <div class="font-ui" style="font-size: 12px; color: var(--candle); margin-top: 12px;">⚠️ Thay đổi nhiệt độ có thể mất 5-10 phút để ổn định</div>
        </div>
    }

    <!-- Slot Grid -->
    <div style="padding: 24px; border-radius: 12px; background-color: var(--bg-card); border: 1px solid var(--border-primary); margin-bottom: 32px;">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
            <h3 class="font-ui" style="font-size: 14px; font-weight: 600; margin: 0; color: var(--text-primary);">📋 Chi tiết từng ngăn</h3>
            <div style="display: flex; background-color: var(--bg-elevated); border: 1px solid var(--border-primary); border-radius: 8px; overflow: hidden; padding: 2px;">
                <button @onclick="() => _isGridView = true" style="padding: 6px 12px; border: none; border-radius: 6px; background: @(_isGridView ? "#3B82F6" : "transparent"); color: @(_isGridView ? "white" : "var(--text-secondary)"); font-size: 12px; font-weight: 500; display: flex; align-items: center; gap: 6px; cursor: pointer; transition: all 0.2s;">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"></rect><rect x="14" y="3" width="7" height="7"></rect><rect x="14" y="14" width="7" height="7"></rect><rect x="3" y="14" width="7" height="7"></rect></svg>
                    Grid
                </button>
                <button @onclick="() => _isGridView = false" style="padding: 6px 12px; border: none; border-radius: 6px; background: @(!_isGridView ? "#3B82F6" : "transparent"); color: @(!_isGridView ? "white" : "var(--text-secondary)"); font-size: 12px; font-weight: 500; display: flex; align-items: center; gap: 6px; cursor: pointer; transition: all 0.2s;">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 3H5a2 2 0 0 0-2 2v4m6-6h10a2 2 0 0 1 2 2v4M9 3v18m0 0h10a2 2 0 0 0 2-2V9M9 21H5a2 2 0 0 1-2-2V9m0 0h18"></path></svg>
                    Table
                </button>
            </div>
        </div>
        
        @if (_isGridView)
        {
            <div style="display: grid; grid-template-columns: repeat(5, 1fr); gap: 16px;">
                @foreach (var kvp in GetCombinedSlotTemperatures())
                {
                    var temp = kvp.Value;
                    var color = GetSlotColor(kvp.Key, temp);
                    var style = GetSlotStyle(kvp.Key, temp);
                    
                    <div style="@style padding: 16px; border-radius: 12px; text-align: center; display: flex; flex-direction: column; align-items: center; justify-content: center; transition: all 0.2s;">
                        <div class="font-ui" style="font-weight: 700; font-size: 12px; color: var(--text-secondary); margin-bottom: 4px;">@kvp.Key</div>
                        <div class="font-mono" style="font-size: 18px; font-weight: 700; color: @color;">@temp.ToString("F1")°C</div>
                        
                        <div style="margin-top: 8px; margin-bottom: 8px;">
                            @((MarkupString)GenerateSparkline(kvp.Key, temp, color))
                        </div>

                        <div style="width: 6px; height: 6px; border-radius: 50%; background-color: @color; opacity: 0.8; box-shadow: 0 0 8px @color;"></div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="overflow-x-auto">
                <table class="w-full data-table">
                    <thead>
                        <tr style="border-bottom: 1px solid var(--table-border);">
                            <th class="px-4 py-3 font-ui text-[11px] uppercase tracking-wider text-left" style="color: var(--text-muted);">Mã Ngăn</th>
                            <th class="px-4 py-3 font-ui text-[11px] uppercase tracking-wider text-left" style="color: var(--text-muted);">Nhiệt độ hiện tại</th>
                            <th class="px-4 py-3 font-ui text-[11px] uppercase tracking-wider text-left" style="color: var(--text-muted);">Trạng thái</th>
                            <th class="px-4 py-3 font-ui text-[11px] uppercase tracking-wider text-left" style="color: var(--text-muted);">Biểu đồ (30p qua)</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var kvp in GetCombinedSlotTemperatures())
                        {
                            var temp = kvp.Value;
                            var color = GetSlotColor(kvp.Key, temp);
                            var statusText = color == "#EF4444" ? "Cảnh báo" : color == "#F59E0B" ? "Chú ý" : "Bình thường";
                            var statusBg = color == "#EF4444" ? "rgba(239,68,68,0.15)" : color == "#F59E0B" ? "rgba(245,158,11,0.15)" : "rgba(16,185,129,0.15)";
                            
                            <tr style="border-bottom: 1px solid var(--table-border);">
                                <td class="px-4 py-3 font-ui text-sm font-bold" style="color: var(--text-primary);">@kvp.Key</td>
                                <td class="px-4 py-3 font-mono text-sm font-semibold" style="color: @color;">@temp.ToString("F1")°C</td>
                                <td class="px-4 py-3">
                                    <span class="badge-pill font-ui text-xs px-2.5 py-0.5 rounded-full font-medium" style="background-color: @statusBg; color: @color;">
                                        @statusText
                                    </span>
                                </td>
                                <td class="px-4 py-2">
                                    @((MarkupString)GenerateSparkline(kvp.Key, temp, color))
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>

    <!-- History Chart -->
    <div style="padding: 24px; border-radius: 12px; background-color: var(--bg-card); border: 1px solid var(--border-primary);">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
            <h3 class="font-ui" style="font-size: 14px; font-weight: 600; margin: 0; color: var(--text-primary);">📈 Lịch sử nhiệt độ</h3>
            <div style="display: flex; align-items: center; gap: 16px;">
                <div style="display: flex; gap: 12px; font-size: 12px; color: var(--text-secondary);">
                    <div style="display: flex; align-items: center; gap: 6px;">
                        <span style="width: 8px; height: 8px; border-radius: 50%; background-color: var(--ice);"></span>
                        <span class="font-ui">Khu A</span>
                    </div>
                    <div style="display: flex; align-items: center; gap: 6px;">
                        <span style="width: 8px; height: 8px; border-radius: 50%; background-color: var(--success);"></span>
                        <span class="font-ui">Khu B</span>
                    </div>
                    <div style="display: flex; align-items: center; gap: 6px;">
                        <span style="width: 8px; height: 8px; border-radius: 50%; background-color: #3B82F6;"></span>
                        <span class="font-ui">Khu C</span>
                    </div>
                </div>
                <div style="display: flex; gap: 4px; border-left: 1px solid var(--border-primary); padding-left: 16px;">
                    @foreach (var r in new[] { "6 giờ", "24 giờ", "7 ngày", "30 ngày" })
                    {
                        <button class="font-ui" style="padding: 4px 12px; border: 1px solid var(--border-primary); border-radius: 6px; background: transparent; color: var(--text-secondary); cursor: pointer; font-size: 11px;">@r</button>
                    }
                </div>
            </div>
        </div>
        
        <div style="position: relative; height: 240px; width: 100%;">
            <!-- Grid Lines -->
            <div style="position: absolute; inset: 0; display: flex; flex-direction: column; justify-content: space-between; pointer-events: none;">
                @foreach (var label in new[] { "6°C", "2°C", "-2°C", "-6°C" })
                {
                    <div style="display: flex; align-items: center; width: 100%; height: 0;">
                        <span class="font-ui" style="font-size: 10px; color: var(--text-muted); width: 30px; text-align: right; margin-right: 8px; transform: translateY(2px);">@label</span>
                        <div style="flex: 1; border-top: 1px dashed var(--border-primary); opacity: 0.5;"></div>
                    </div>
                }
            </div>

            <!-- SVG Line Chart -->
            @{
                var ptsA = GetPolylinePoints(d => d.ZoneA);
                var ptsB = GetPolylinePoints(d => d.ZoneB);
                var ptsC = GetPolylinePoints(d => d.ZoneC);
            }
            <svg viewBox="0 0 1000 240" preserveAspectRatio="none" style="position: absolute; top: 0; left: 38px; width: calc(100% - 38px); height: 100%; overflow: visible;">
                <defs>
                    <linearGradient id="gradA" x1="0" y1="0" x2="0" y2="1">
                        <stop offset="0%" stop-color="var(--ice)" stop-opacity="0.3"/>
                        <stop offset="100%" stop-color="var(--ice)" stop-opacity="0.0"/>
                    </linearGradient>
                    <linearGradient id="gradB" x1="0" y1="0" x2="0" y2="1">
                        <stop offset="0%" stop-color="var(--success)" stop-opacity="0.3"/>
                        <stop offset="100%" stop-color="var(--success)" stop-opacity="0.0"/>
                    </linearGradient>
                    <linearGradient id="gradC" x1="0" y1="0" x2="0" y2="1">
                        <stop offset="0%" stop-color="#3B82F6" stop-opacity="0.3"/>
                        <stop offset="100%" stop-color="#3B82F6" stop-opacity="0.0"/>
                    </linearGradient>
                </defs>

                <!-- Zone C -->
                <polygon points="@GetPolygonPoints(ptsC)" fill="url(#gradC)" />
                <polyline points="@ptsC" fill="none" stroke="#3B82F6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                
                <!-- Zone B -->
                <polygon points="@GetPolygonPoints(ptsB)" fill="url(#gradB)" />
                <polyline points="@ptsB" fill="none" stroke="var(--success)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                
                <!-- Zone A -->
                <polygon points="@GetPolygonPoints(ptsA)" fill="url(#gradA)" />
                <polyline points="@ptsA" fill="none" stroke="var(--ice)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
            </svg>

            <!-- X Axis Labels -->
            <div style="position: absolute; bottom: -20px; left: 38px; right: 0; display: flex; justify-content: space-between;">
                @for (int i = 0; i <= 24; i += 4)
                {
                    <span class="font-ui" style="font-size: 10px; color: var(--text-muted);">@(i == 24 ? "Hiện tại" : $"-{24-i}h")</span>
                }
            </div>
        </div>
    </div>
</div>

<ConfirmDialog IsVisible="@_showTempConfirm"
               Title="Xác nhận điều chỉnh nhiệt độ"
               Message="@($"Xác nhận thay đổi nhiệt độ đích của Khu vực {_tempConfirmZone} thành {_tempConfirmValue:0.0}°C?\nViệc điều chỉnh nhiệt độ cần 5-10 phút để ổn định và có thể ảnh hưởng đến các mẫu vật đang bảo quản.")"
               ConfirmText="Xác nhận áp dụng"
               CancelText="Hủy"
               Type="warning"
               OnConfirm="ConfirmSetTarget"
               OnCancel="() => _showTempConfirm = false" />

@code {
    private string? _expandedZone;
    private double _zoneCTarget = -5.0;
    private double _zoneCCurrent = -4.8;
    private Dictionary<string, double> _cSlotTemps = new()
    {
        { "C-01", -4.8 },
        { "C-02", -5.2 },
        { "C-03", -5.0 },
        { "C-04", -4.6 },
        { "C-05", -4.9 }
    };

    private bool _isGridView = true;

    private void ToggleZoneA() => _expandedZone = _expandedZone == "A" ? null : "A";
    private void ToggleZoneB() => _expandedZone = _expandedZone == "B" ? null : "B";
    private void ToggleZoneC() => _expandedZone = _expandedZone == "C" ? null : "C";
    private string GetZoneALabel() => _expandedZone == "A" ? "Ẩn" : "Điều chỉnh";
    private string GetZoneBLabel() => _expandedZone == "B" ? "Ẩn" : "Điều chỉnh";
    private string GetZoneCLabel() => _expandedZone == "C" ? "Ẩn" : "Điều chỉnh";

    private void OnSliderChange(ChangeEventArgs e)
    {
        if (_expandedZone is not null && double.TryParse(e.Value?.ToString(), out var val))
        {
            if (_expandedZone == "C")
            {
                _zoneCTarget = val;
                UpdateZoneCTemp();
            }
            else
            {
                TempService.SetTarget(_expandedZone, val);
            }
        }
    }

    private readonly List<(double ZoneA, double ZoneB, double ZoneC)> _historyPoints = Enumerable.Range(0, 24).Select(i => {
        var rng = new Random(i);
        return (
            2.0 + Math.Sin(i * 0.3) * 0.5, 
            2.5 + Math.Sin(i * 0.25 + 1) * 0.6,
            -5.0 + Math.Sin(i * 0.2) * 0.4
        );
    }).ToList();

    protected override void OnInitialized()
    {
        TempService.OnTemperatureChanged += Refresh;
        UpdateZoneCTemp();
    }

    private bool _showTempConfirm;
    private string _tempConfirmZone = "";
    private double _tempConfirmValue;

    private void StartSetTarget(string zone, double value)
    {
        _tempConfirmZone = zone;
        _tempConfirmValue = value;
        _showTempConfirm = true;
    }

    private void StartResetZoneTarget(string zone)
    {
        StartSetTarget(zone, zone == "C" ? -5.0 : 2.0);
    }

    private void ConfirmSetTarget()
    {
        _showTempConfirm = false;
        if (_tempConfirmZone == "C")
        {
            _zoneCTarget = _tempConfirmValue;
            UpdateZoneCTemp();
        }
        else
        {
            TempService.SetTarget(_tempConfirmZone, _tempConfirmValue);
        }
    }

    private string GetPresetButtonStyle(string zone, double preset, double currentTarget)
    {
        var active = currentTarget == preset;
        var border = active ? "var(--ice)" : "var(--border-primary)";
        var color = active ? "var(--ice)" : "var(--text-secondary)";
        return $"padding: 8px 16px; border-radius: 8px; font-size: 12px; cursor: pointer; border: 1px solid {border}; color: {color}; background: transparent;";
    }

    private string GetSlotStyle(string key, double temp)
    {
        var isDeepFreeze = key.StartsWith("C");
        var color = isDeepFreeze 
            ? (temp > 0 ? "#EF4444" : temp > -2 ? "#F59E0B" : "#10B981")
            : (temp > 6 ? "#EF4444" : temp > 4 ? "#F59E0B" : "#10B981");
            
        var rgb = color == "#EF4444" ? "239,68,68" : color == "#F59E0B" ? "245,158,11" : "16,185,129";
        return $"border: 1px solid rgba({rgb}, 0.2); background-color: rgba({rgb}, 0.04);";
    }

    private string GetSlotColor(string key, double temp)
    {
        var isDeepFreeze = key.StartsWith("C");
        return isDeepFreeze 
            ? (temp > 0 ? "#EF4444" : temp > -2 ? "#F59E0B" : "#10B981")
            : (temp > 6 ? "#EF4444" : temp > 4 ? "#F59E0B" : "#10B981");
    }

    private string GenerateSparkline(string key, double currentTemp, string color)
    {
        // Seed RNG based on slot key so the line looks stable per slot
        var rng = new Random(key.GetHashCode() + (int)(currentTemp * 10)); 
        var points = new List<string>();
        double width = 50.0;
        double height = 24.0;
        int numPoints = 6;
        
        for (int i = 0; i < numPoints; i++)
        {
            double x = (i / (double)(numPoints - 1)) * width;
            double valVariation = (rng.NextDouble() * 2 - 1); 
            if (i == numPoints - 1) valVariation = 0; // End exactly at current temp
            
            // Map variation to Y coordinate
            double y = height / 2 - valVariation * 8;
            y = Math.Max(2, Math.Min(height - 2, y));
            
            points.Add($"{x.ToString(System.Globalization.CultureInfo.InvariantCulture)},{y.ToString(System.Globalization.CultureInfo.InvariantCulture)}");
        }
        
        var pts = string.Join(" ", points);
        return $"<svg viewBox=\"0 0 50 24\" style=\"width: 50px; height: 24px; overflow: visible;\">" +
               $"<polyline points=\"{pts}\" fill=\"none\" stroke=\"{color}\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\" />" +
               $"</svg>";
    }

    private void Refresh()
    {
        UpdateZoneCTemp();
        InvokeAsync(StateHasChanged);
    }

    private void UpdateZoneCTemp()
    {
        var rng = new Random();
        _zoneCCurrent = Math.Round(_zoneCTarget + (rng.NextDouble() * 0.8 - 0.4), 1);
        for (int i = 1; i <= 5; i++)
        {
            _cSlotTemps[$"C-{i:D2}"] = Math.Round(_zoneCCurrent + (rng.NextDouble() * 0.4 - 0.2), 1);
        }
    }

    private IEnumerable<KeyValuePair<string, double>> GetCombinedSlotTemperatures()
    {
        return TempService.SlotTemperatures.Concat(_cSlotTemps).OrderBy(x => x.Key);
    }

    private string GetPolylinePoints(Func<(double ZoneA, double ZoneB, double ZoneC), double> selector)
    {
        var points = new List<string>();
        double width = 1000.0;
        double height = 240.0;
        double minTemp = -6.0;
        double maxTemp = 6.0;
        double range = maxTemp - minTemp;

        for (int i = 0; i < _historyPoints.Count; i++)
        {
            double x = (i / (double)(_historyPoints.Count - 1)) * width;
            double val = selector(_historyPoints[i]);
            // Clamp value within min-max for robust rendering
            val = Math.Max(minTemp, Math.Min(maxTemp, val));
            double y = height - ((val - minTemp) / range) * height;
            points.Add($"{x.ToString(System.Globalization.CultureInfo.InvariantCulture)},{y.ToString(System.Globalization.CultureInfo.InvariantCulture)}");
        }
        return string.Join(" ", points);
    }
    
    private string GetPolygonPoints(string polylinePoints)
    {
        return $"0,240 {polylinePoints} 1000,240";
    }

    public void Dispose()
    {
        TempService.OnTemperatureChanged -= Refresh;
    }
}
