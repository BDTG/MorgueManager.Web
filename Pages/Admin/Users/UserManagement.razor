@page "/admin/users"
@layout Components.Layout.AdminLayout
@inject NavigationManager Navigation

<div>
    <div style="display: flex; flex-wrap: wrap; justify-content: space-between; align-items: center; gap: 16px; margin-bottom: 24px;">
        <div>
            <div class="font-ui" style="font-size: 12px; color: var(--text-muted); margin-bottom: 4px;">Dashboard / Nhân viên</div>
            <h1 class="font-ui" style="font-size: 22px; font-weight: 700; margin: 0; color: var(--text-primary);">👥 Quản lý Nhân viên</h1>
        </div>
        <div style="display: flex; gap: 8px;">
            <button @onclick="() => _showCreateModal = true" class="font-ui" style="padding: 8px 16px; border-radius: 8px; font-size: 12px; font-weight: 600; cursor: pointer; border: none; background: linear-gradient(135deg, #3B82F6, #2563EB); color: white;">➕ Thêm nhân viên</button>
            <button class="font-ui" style="padding: 8px 16px; border-radius: 8px; font-size: 12px; cursor: pointer; border: 1px solid var(--success); color: var(--success); background: transparent;">📥 Xuất danh sách</button>
        </div>
    </div>

    <div class="filter-bar">
        <input class="filter-input" placeholder="🔍 Tìm theo tên, email..." />
        <select class="filter-select">
            <option value="">Tất cả vai trò</option>
            <option>Admin</option>
            <option>Manager</option>
            <option>Staff</option>
        </select>
        <select class="filter-select">
            <option value="">Tất cả trạng thái</option>
            <option>Hoạt động</option>
            <option>Tạm khóa</option>
        </select>
    </div>

    <div style="border-radius: 12px; border: 1px solid var(--border-primary); overflow: hidden; background-color: var(--bg-card);">
        <table class="data-table">
            <thead><tr><th>#</th><th>Avatar</th><th>Họ tên</th><th>Email</th><th>SĐT</th><th>Vai trò</th><th>Trạng thái</th><th>Ngày tham gia</th><th>Hành động</th></tr></thead>
            <tbody>
                @foreach (var u in _users)
                {
                    <tr>
                        <td>@u.Id</td>
                        <td><div style="width: 32px; height: 32px; border-radius: 50%; background-color: var(--bg-elevated); display: flex; align-items: center; justify-content: center; font-size: 14px;">👤</div></td>
                        <td><span class="font-ui" style="font-weight: 500;">@u.Name</span></td>
                        <td style="font-size: 12px; color: var(--text-secondary);">@u.Email</td>
                        <td style="font-family: monospace; font-size: 12px;">@u.Phone</td>
                        <td><span class="badge-pill" style="background-color: @(u.RoleBg); color: @(u.RoleText);">@u.Role</span></td>
                        <td><span style="display: flex; align-items: center; gap: 4px; font-size: 13px; color: @(u.IsActive ? "var(--success)" : "var(--danger)");"><span style="width: 6px; height: 6px; border-radius: 50%; background-color: currentColor;"></span> @(u.IsActive ? "Hoạt động" : "Tạm khóa")</span></td>
                        <td style="font-size: 12px;">@u.JoinDate</td>
                        <td>
                            <div style="display: flex; gap: 2px;">
                                <button class="font-ui" style="background: none; border: none; cursor: pointer; font-size: 14px;" title="Xem">👁️</button>
                                <button class="font-ui" style="background: none; border: none; cursor: pointer; font-size: 14px;" title="Sửa">✏️</button>
                                <button @onclick="NavToShifts" class="font-ui" style="background: none; border: none; cursor: pointer; font-size: 14px;" title="Xem lịch trực">📅</button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@if (_showCreateModal)
{
    <Modal OnClose="() => _showCreateModal = false">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px;">
            <h2 class="font-ui" style="font-size: 18px; font-weight: 700; margin: 0; color: var(--text-primary);">➕ Thêm nhân viên mới</h2>
            <button @onclick="() => _showCreateModal = false" style="background: none; border: none; color: var(--text-muted); font-size: 20px; cursor: pointer;">✕</button>
        </div>
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
            <div>
                <label class="font-ui" style="font-size: 11px; text-transform: uppercase; color: var(--text-muted); display: block; margin-bottom: 6px;">Họ tên *</label>
                <input class="filter-input" style="width: 100%;" />
            </div>
            <div>
                <label class="font-ui" style="font-size: 11px; text-transform: uppercase; color: var(--text-muted); display: block; margin-bottom: 6px;">Email *</label>
                <input type="email" class="filter-input" style="width: 100%;" />
            </div>
            <div>
                <label class="font-ui" style="font-size: 11px; text-transform: uppercase; color: var(--text-muted); display: block; margin-bottom: 6px;">Số điện thoại</label>
                <input class="filter-input" style="width: 100%;" />
            </div>
            <div>
                <label class="font-ui" style="font-size: 11px; text-transform: uppercase; color: var(--text-muted); display: block; margin-bottom: 6px;">Vai trò</label>
                <select class="filter-select" style="width: 100%;">
                    <option>Staff</option>
                    <option>Manager</option>
                    <option>Admin</option>
                </select>
            </div>
        </div>
        <div style="display: flex; justify-content: flex-end; gap: 12px; margin-top: 24px;">
            <button @onclick="() => _showCreateModal = false" class="font-ui" style="padding: 10px 20px; border: 1px solid var(--border-primary); border-radius: 8px; background: transparent; color: var(--text-secondary); cursor: pointer; font-size: 13px;">Hủy</button>
            <button class="font-ui" style="padding: 10px 20px; border: none; border-radius: 8px; background: linear-gradient(135deg, #3B82F6, #2563EB); color: white; cursor: pointer; font-size: 13px; font-weight: 600;">💾 Lưu</button>
        </div>
    </Modal>
}

@code {
    private bool _showCreateModal;

    private readonly List<UserItem> _users = new()
    {
        new() { Id = 1, Name = "Nguyễn Văn A", Email = "admin@morgue.vn", Phone = "+84 912 345 678", Role = "Admin", RoleBg = "rgba(239,68,68,0.15)", RoleText = "#EF4444", IsActive = true, JoinDate = "01/01/2026" },
        new() { Id = 2, Name = "Trần Thị B", Email = "tranthib@morgue.vn", Phone = "+84 987 654 321", Role = "Manager", RoleBg = "rgba(245,158,11,0.15)", RoleText = "#F59E0B", IsActive = true, JoinDate = "15/02/2026" },
        new() { Id = 3, Name = "Lê Văn C", Email = "levanc@morgue.vn", Phone = "+84 923 456 789", Role = "Staff", RoleBg = "rgba(59,130,246,0.15)", RoleText = "#3B82F6", IsActive = false, JoinDate = "01/03/2026" },
        new() { Id = 4, Name = "Phạm Thị D", Email = "phamthid@morgue.vn", Phone = "+84 934 567 890", Role = "Staff", RoleBg = "rgba(59,130,246,0.15)", RoleText = "#3B82F6", IsActive = true, JoinDate = "10/03/2026" },
    };

    private void NavToShifts() => Navigation.NavigateTo("/admin/shifts");

    private class UserItem
    {
        public int Id { get; set; }
        public string Name { get; set; } = "";
        public string Email { get; set; } = "";
        public string Phone { get; set; } = "";
        public string Role { get; set; } = "";
        public string RoleBg { get; set; } = "";
        public string RoleText { get; set; } = "";
        public bool IsActive { get; set; }
        public string JoinDate { get; set; } = "";
    }
}
