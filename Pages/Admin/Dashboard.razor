@page "/admin/dashboard"
@layout Components.Layout.AdminLayout
@inject NavigationManager Navigation
@inject TemperatureSimulatorService TempService
@inject IJSRuntime JS
@implements IDisposable

<div class="min-h-screen pt-4 pb-12">
    <div class="max-w-[1400px] mx-auto">
        <!-- Header -->
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-8">
            <div>
                <div class="flex items-center gap-2 font-ui text-xs mb-1" style="color: var(--text-muted);">
                    <span>Dashboard</span>
                </div>
                <h1 class="font-ui text-2xl font-bold" style="color: var(--text-primary);">
                    Xin chào, Admin 👋
                </h1>
                <p class="font-ui text-sm mt-1" style="color: var(--text-secondary);">
                    @_currentTime.ToString("dddd, dd/MM/yyyy", new System.Globalization.CultureInfo("vi-VN")) · @_currentTime.ToString("HH:mm:ss")
                </p>
            </div>
        </div>

        <!-- KPI Cards Grid -->
        <div class="grid grid-cols-2 md:grid-cols-5 gap-4 mb-8">
            <KpiCard Icon="users" Label="Tổng thi thể" Value="127" SubText="+3 tuần này" Color="#3B82F6" OnClick="NavToCorpses" />
            <KpiCard Icon="snowflake" Label="Đang lưu kho" Value="10" SubText="Hiện tại" Color="#0EA5E9" OnClick="NavToCorpses" />
            <KpiCard Icon="alert-triangle" Label="Quá hạn / Cảnh báo" Value="2 / 3" Color="#EF4444" OnClick="NavToCorpses" />
            <KpiCard Icon="check-square" Label="Đã bàn giao" Value="8" SubText="Tháng này" Color="#10B981" OnClick="NavToCorpses" />
            <KpiCard Icon="thermometer" Label="Cảnh báo nhiệt độ" Value="3" SubText="Ngăn bất thường" Color="#F59E0B" OnClick="NavToTemperature" />
        </div>

        <!-- Charts + Overdue Grid -->
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-8">
            <!-- Chart Container -->
            <div class="lg:col-span-2 rounded-xl p-6 relative" style="background-color: var(--bg-card); border: 1px solid var(--border-primary);">
                <div class="flex items-start justify-between mb-8">
                    <div>
                        <h3 class="font-ui text-base font-bold flex items-center gap-2" style="color: var(--text-primary);">
                            <span>Hoạt động Tiếp nhận & Bàn giao</span>
                        </h3>
                        <span class="font-ui text-xs mt-1 block" style="color: var(--text-muted);">Số lượng thi thể tiếp nhận vs bàn giao mỗi ngày</span>
                    </div>
                    <div class="flex items-center gap-4">
                        <div class="flex items-center gap-1.5">
                            <span class="w-3 h-3 rounded-full" style="background-color: #C8D6E5;"></span>
                            <span class="font-ui text-xs" style="color: var(--text-secondary);">Tiếp nhận</span>
                        </div>
                        <div class="flex items-center gap-1.5">
                            <span class="w-3 h-3 rounded-full" style="background-color: #6B85A0;"></span>
                            <span class="font-ui text-xs" style="color: var(--text-secondary);">Bàn giao</span>
                        </div>
                    </div>
                </div>
                
                <!-- Chart Area -->
                <div class="relative h-48 w-full mt-4">
                    <!-- Y Axis Lines -->
                    <div class="absolute inset-0 flex flex-col justify-between pointer-events-none">
                        @foreach (var val in new[] { 20, 15, 10, 5, 0 })
                        {
                            <div class="flex items-center w-full h-0">
                                <span class="w-6 text-right font-ui text-[10px] pr-2 translate-y-[2px]" style="color: var(--text-muted);">@val</span>
                                <div class="flex-1 border-t border-dashed" style="border-color: var(--border-primary); opacity: 0.6;"></div>
                            </div>
                        }
                    </div>

                    <!-- Bars -->
                    <div class="absolute inset-0 pl-6 flex items-end justify-between px-2 pb-[1px]">
                        @foreach (var day in _weeklyData)
                        {
                            var h1 = (day.Admissions / 20.0) * 100;
                            var h2 = (day.Releases / 20.0) * 100;

                            <div class="chart-column relative group flex items-end justify-center w-full h-[110%] rounded-lg transition-colors duration-200 cursor-pointer hover:bg-[rgba(148,179,210,0.1)] pb-[1px]"
                                 data-day="@day.Day" data-admissions="@day.Admissions" data-releases="@day.Releases">
                                
                                <!-- Bars for the day -->
                                <div class="flex items-end gap-[3px] w-[50%] h-[90.9%] justify-center pointer-events-none">
                                    <div class="w-full rounded-t-sm transition-all duration-300" style="height: @(h1)%; background-color: #C8D6E5;"></div>
                                    <div class="w-full rounded-t-sm transition-all duration-300" style="height: @(h2)%; background-color: #6B85A0;"></div>
                                </div>
                            </div>
                        }
                    </div>
                </div>

                <!-- X Axis Labels -->
                <div class="pl-6 flex items-center justify-between px-2 mt-2">
                    @foreach (var day in _weeklyData)
                    {
                        <div class="w-full text-center font-ui text-[11px]" style="color: var(--text-muted);">@day.Day</div>
                    }
                </div>
                
                <!-- Chart Footer -->
                <div class="flex items-center justify-between mt-4 pt-4" style="border-top: 1px solid var(--border-primary);">
                    <div class="flex items-center gap-2">
                        <LucideIcon Name="thermometer" Class="w-3.5 h-3.5" Style="color: var(--ice);" />
                        <span class="font-ui text-xs" style="color: var(--text-muted);">Nhiệt độ TB ngăn lạnh:</span>
                        <span class="font-ui text-sm font-semibold font-mono" style="color: var(--success);">@TempService.ZoneACurrent.ToString("F1")°C</span>
                    </div>
                    <div class="flex items-center gap-2">
                        <LucideIcon Name="activity" Class="w-3.5 h-3.5" Style="color: var(--success);" />
                        <span class="font-ui text-xs" style="color: var(--text-muted);">Hệ thống hoạt động bình thường</span>
                    </div>
                </div>
            </div>

            <!-- Storage Utilization Container -->
            <div class="rounded-xl p-6 relative" style="background-color: var(--bg-card); border: 1px solid var(--border-primary);">
                <div class="flex items-center justify-between mb-6">
                    <div>
                        <h3 class="font-ui text-sm font-semibold flex items-center gap-2" style="color: var(--text-primary);">
                            <span>Công suất Lưu trữ</span>
                        </h3>
                        <p class="mt-0.5 text-xs" style="color: var(--text-muted);">Số khoang đã sử dụng theo khu vực</p>
                    </div>
                    <div class="text-right">
                        <p class="text-2xl font-bold" style="color: var(--text-primary);">
                            @(Math.Round((double)_storageUnits.Sum(u => u.Occupied) / _storageUnits.Sum(u => u.Total) * 100))%
                        </p>
                        <p class="text-[10px] font-medium uppercase tracking-wider" style="color: var(--text-muted);">Công suất tổng</p>
                    </div>
                </div>

                <div class="flex flex-col gap-6">
                    <div class="flex justify-center">
                        <svg viewBox="0 0 100 100" class="w-32 h-32 transform -rotate-90 overflow-visible drop-shadow-sm">
                            <circle cx="50" cy="50" r="40" fill="none" pointer-events="none" stroke="var(--bg-elevated)" stroke-width="16" />
                            @foreach (var slice in GetDonutSlices())
                            {
                                <circle cx="50" cy="50" r="40" fill="none" pointer-events="stroke" stroke="@slice.Color" stroke-width="16"
                                        stroke-dasharray="@slice.StrokeDashArray.ToString(System.Globalization.CultureInfo.InvariantCulture) 300"
                                        stroke-dashoffset="@slice.StrokeDashOffset.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                                        class="transition-all duration-300 hover:stroke-[20] cursor-pointer donut-slice"
                                        data-name="@slice.Name" data-occupied="@slice.Occupied" data-total="@slice.Total" style="outline: none;" />
                            }
                        </svg>
                    </div>

                    <div class="flex flex-col gap-3">
                        @foreach (var unit in _storageUnits)
                        {
                            var util = Math.Round((unit.Occupied / (double)unit.Total) * 100);
                            <div class="space-y-1.5">
                                <div class="flex items-center justify-between text-xs">
                                    <div class="flex items-center gap-2">
                                        <span class="w-2.5 h-2.5 rounded-sm" style="background-color: @unit.Color;"></span>
                                        <span style="color: var(--text-secondary);">@unit.Name</span>
                                    </div>
                                    <span class="font-medium" style="color: var(--text-muted);">@unit.Occupied/@unit.Total</span>
                                </div>
                                <div class="h-1.5 w-full overflow-hidden rounded-full" style="background-color: var(--input-bg-solid); border: 1px solid var(--border-primary);">
                                    <div class="h-full rounded-full transition-all duration-500" style="width: @(util)%; background-color: @unit.Color;"></div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- Quick Links -->
        <h3 class="font-ui text-sm font-semibold mb-4 flex items-center gap-2" style="color: var(--text-primary);">
            <LucideIcon Name="package" Class="w-4 h-4" Style="color: var(--ice);" /> 
            <span>Truy cập nhanh</span>
        </h3>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
            @foreach (var link in _quickLinks)
            {
                <button @onclick="() => Navigation.NavigateTo(link.Route)" 
                        class="w-full text-left rounded-xl p-5 transition-all duration-300 hover:-translate-y-0.5 group cursor-pointer"
                        style="background-color: var(--bg-card); border: 1px solid var(--border-primary);"
                        onmouseenter="this.style.borderColor='@(link.Color + "40")';"
                        onmouseleave="this.style.borderColor='var(--border-primary)';">
                    <div class="flex items-start justify-between mb-3">
                        <div class="w-10 h-10 rounded-lg flex items-center justify-center" style="background-color: @(link.Color + "15");">
                            <LucideIcon Name="@link.Icon" Class="w-5 h-5" Style="@($"color: {link.Color};")" />
                        </div>
                        <LucideIcon Name="arrow-right" Class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-1" Style="color: var(--text-muted);" />
                    </div>
                    <div class="font-ui text-sm font-semibold" style="color: var(--text-primary);">@link.Title</div>
                    <div class="font-ui text-xs mt-0.5" style="color: var(--text-muted);">@link.Desc</div>
                </button>
            }
        </div>

        <!-- Bottom Grid: Overdue & Recent Activity -->
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-8">
            <!-- Overdue List -->
            <div class="rounded-xl p-6 h-full" style="background-color: var(--bg-card); border: 1px solid var(--border-primary);">
                <div class="flex items-center justify-between mb-4">
                    <h3 class="font-ui text-sm font-semibold flex items-center gap-2" style="color: var(--text-primary);">
                        <LucideIcon Name="alert-triangle" Class="w-4 h-4" Style="color: var(--danger);" /> 
                        <span>Cần xử lý</span>
                    </h3>
                    <a href="/admin/corpses" class="font-ui text-xs hover:underline" style="color: var(--ice); text-decoration: none;">Xem tất cả</a>
                </div>
                
                <div class="space-y-2 flex flex-col gap-2">
                    @foreach (var c in _overdueList)
                    {
                        <div class="flex items-center justify-between p-3 rounded-lg transition-all duration-200 cursor-pointer"
                             style="background-color: var(--bg-elevated); border: 1px solid var(--border-primary);"
                             onmouseenter="this.style.borderColor='rgba(239,68,68,0.3)';"
                             onmouseleave="this.style.borderColor='var(--border-primary)';"
                             @onclick="NavToCorpses">
                            <div class="flex items-center gap-3">
                                <span class="w-2 h-2 rounded-full flex-shrink-0" style="background-color: @(c.Days >= 14 ? "#EF4444" : "#F59E0B");"></span>
                                <div>
                                    <div class="font-ui text-sm font-medium" style="color: var(--text-primary);">@c.Name</div>
                                    <div class="font-ui text-xs font-mono" style="color: var(--text-muted);">@c.CaseId</div>
                                </div>
                            </div>
                            <div class="text-right">
                                <div class="font-ui text-sm font-semibold" style="color: @(c.Days >= 14 ? "#EF4444" : "#F59E0B");">@c.Days ngày</div>
                                <div class="font-ui text-xs" style="color: var(--text-muted);">@c.Slot</div>
                            </div>
                        </div>
                    }
                </div>
            </div>

            <!-- Recent Activity Table -->
            <div class="lg:col-span-2 rounded-xl p-6 h-full" style="background-color: var(--bg-card); border: 1px solid var(--border-primary);">
                <h3 class="font-ui text-sm font-semibold mb-4 flex items-center gap-2" style="color: var(--text-primary);">
                    <LucideIcon Name="search" Class="w-4 h-4" Style="color: var(--ice);" /> 
                    <span>Hoạt động gần đây</span>
                </h3>
                <div class="overflow-x-auto">
                    <table class="w-full data-table">
                        <thead>
                            <tr style="border-bottom: 1px solid var(--table-border);">
                                <th class="px-3 py-2 font-ui text-[10px] uppercase tracking-wider text-left" style="color: var(--text-muted);">Thời gian</th>
                                <th class="px-3 py-2 font-ui text-[10px] uppercase tracking-wider text-left" style="color: var(--text-muted);">Hành động</th>
                                <th class="px-3 py-2 font-ui text-[10px] uppercase tracking-wider text-left" style="color: var(--text-muted);">Đối tượng</th>
                                <th class="px-3 py-2 font-ui text-[10px] uppercase tracking-wider text-left" style="color: var(--text-muted);">Người thực hiện</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var row in _recentActivity)
                            {
                                <tr style="border-bottom: 1px solid var(--table-border);">
                                    <td class="px-3 py-2.5 font-ui text-xs font-mono" style="color: var(--text-muted);">@row.Time</td>
                                    <td class="px-3 py-2.5">
                                        <span class="badge-pill font-ui text-xs px-2.5 py-0.5 rounded-full font-medium"
                                              style="background-color: @row.BadgeBg; color: @row.BadgeText;">
                                            @row.Action
                                        </span>
                                    </td>
                                    <td class="px-3 py-2.5 font-ui text-sm" style="color: var(--text-primary);">@row.Target</td>
                                    <td class="px-3 py-2.5 font-ui text-xs" style="color: var(--text-secondary);">@row.By</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
        <!-- Dynamic JS Tooltip -->
        <div id="dashboard-tooltip" style="position: fixed; left: 0px; top: 0px; z-index: 9999; pointer-events: none; opacity: 0; background-color: var(--login-card-bg); border: 1px solid var(--border-primary); box-shadow: var(--shadow-lg); backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);"
             class="w-36 p-3 rounded-xl transition-opacity duration-150 ease-out">
            <div id="tooltip-day" class="font-ui text-xs font-semibold mb-2" style="color: var(--text-primary);"></div>
            <div class="flex justify-between items-center text-xs mb-1.5">
                <div class="flex items-center gap-1.5">
                    <span class="w-2 h-2 rounded-full" style="background-color: #C8D6E5;"></span>
                    <span style="color: var(--text-secondary);">Tiếp nhận:</span>
                </div>
                <span id="tooltip-admissions" class="font-semibold" style="color: var(--text-primary);"></span>
            </div>
            <div class="flex justify-between items-center text-xs">
                <div class="flex items-center gap-1.5">
                    <span class="w-2 h-2 rounded-full" style="background-color: #6B85A0;"></span>
                    <span style="color: var(--text-secondary);">Bàn giao:</span>
                </div>
                <span id="tooltip-releases" class="font-semibold" style="color: var(--text-primary);"></span>
            </div>
        </div>

        <!-- Donut Tooltip -->
        <div id="donut-tooltip" style="position: fixed; left: 0px; top: 0px; z-index: 9999; pointer-events: none; opacity: 0; background-color: var(--login-card-bg); border: 1px solid var(--border-primary); box-shadow: var(--shadow-lg); backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);"
             class="w-48 p-3 rounded-xl transition-opacity duration-150 ease-out">
            <div id="donut-name" class="font-ui text-sm font-semibold mb-2" style="color: var(--text-primary);"></div>
            <div class="space-y-1.5 font-ui text-xs">
                <div class="flex justify-between items-center">
                    <span style="color: var(--text-secondary);">Đã sử dụng:</span>
                    <span id="donut-occupied" class="font-medium" style="color: var(--text-primary);"></span>
                </div>
                <div class="flex justify-between items-center">
                    <span style="color: var(--text-secondary);">Còn trống:</span>
                    <span id="donut-available" class="font-medium" style="color: var(--text-primary);"></span>
                </div>
                <div class="flex justify-between items-center">
                    <span style="color: var(--text-secondary);">Sức chứa:</span>
                    <span id="donut-total" class="font-medium" style="color: var(--text-primary);"></span>
                </div>
                <div class="mt-2 pt-2 border-t" style="border-color: var(--border-primary);">
                    <div class="flex justify-between items-center">
                        <span style="color: var(--text-secondary);">Tỉ lệ sử dụng:</span>
                        <span id="donut-util" class="font-semibold"></span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private System.Threading.Timer? _timer;
    private DateTime _currentTime = DateTime.Now;

    private readonly List<(string Day, int Admissions, int Releases)> _weeklyData = new()
    {
        new("Mon", 8, 5),
        new("Tue", 12, 7),
        new("Wed", 20, 11),
        new("Thu", 6, 15),
        new("Fri", 4, 7),
        new("Sat", 18, 6),
        new("Sun", 11, 10)
    };

    private readonly List<(string Name, int Total, int Occupied, string Color)> _storageUnits = new()
    {
        new("Phòng lạnh A", 40, 38, "#3b82f6"),
        new("Phòng lạnh B", 40, 35, "#06b6d4"),
        new("Phòng lạnh C", 40, 28, "#6366f1"),
        new("Ngăn đông 1", 30, 24, "#8b5cf6"),
        new("Ngăn đông 2", 30, 22, "#a855f7"),
        new("Khu vực khâm liệm", 20, 0, "#22c55e"),
    };

    private IEnumerable<(string Name, int Total, int Occupied, string Color, double StrokeDashArray, double StrokeDashOffset)> GetDonutSlices()
    {
        double r = 40;
        double circumference = 2 * Math.PI * r;
        int totalOccupied = _storageUnits.Sum(u => u.Occupied);
        double accumulated = 0;

        foreach (var unit in _storageUnits)
        {
            if (unit.Occupied == 0) continue;
            
            double fraction = unit.Occupied / (double)totalOccupied;
            double length = fraction * circumference;
            double offset = -accumulated;
            
            yield return (unit.Name, unit.Total, unit.Occupied, unit.Color, length, offset);
            
            accumulated += length;
        }
    }
    private readonly List<(string Name, string CaseId, int Days, string Slot)> _overdueList = new()
    {
        new("Nguyễn Văn An", "MC-2026-0127", 18, "A-03"),
        new("Trần Thị Bích", "MC-2026-0120", 14, "B-02"),
        new("Lê Hoàng Nam", "MC-2026-0115", 9, "A-07"),
        new("Phạm Minh Tuấn", "MC-2026-0110", 8, "B-05"),
        new("Hoàng Thị Lan", "MC-2026-0108", 7, "A-01"),
    };

    private readonly List<(string Icon, string Title, string Desc, string Color, string Route)> _quickLinks = new()
    {
        new("users", "Quản lý Thi thể", "Danh sách, thêm, sửa, xóa", "#3B82F6", "/admin/corpses"),
        new("snowflake", "Ngăn Lưu trữ", "Sơ đồ ngăn tủ real-time", "#0EA5E9", "/admin/storages"),
        new("calendar", "Phân ca Trực", "Lịch trực & nhắc nhở", "#8B5CF6", "/admin/shifts"),
        new("bar-chart-3", "Báo cáo", "Thống kê & xuất file", "#10B981", "/admin/reports"),
    };

    private readonly List<(string Time, string Action, string Target, string By, string BadgeBg, string BadgeText)> _recentActivity = new()
    {
        new("10:30", "Tiếp nhận", "MC-2026-0127", "Nguyễn Thị B", "var(--badge-tiepnhan-bg)", "var(--badge-tiepnhan-text)"),
        new("10:15", "Chuyển ngăn", "A-03 → A-05", "Trần Văn C", "var(--badge-luukho-bg)", "var(--badge-luukho-text)"),
        new("09:45", "Bàn giao", "MC-2026-0089", "Lê Thị D", "var(--badge-bangiao-bg)", "var(--badge-bangiao-text)"),
        new("09:20", "Cập nhật nhiệt độ", "Cold Room A", "Hệ thống", "var(--badge-luukho-bg)", "var(--badge-luukho-text)"),
        new("08:55", "Tiếp nhận", "MC-2026-0126", "Nguyễn Thị B", "var(--badge-tiepnhan-bg)", "var(--badge-tiepnhan-text)"),
    };

    protected override void OnInitialized()
    {
        // Khởi tạo timer cập nhật đồng hồ mỗi giây
        _timer = new System.Threading.Timer(Callback, null, 0, 1000);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("initDashboardTooltip");
        }
    }

    private bool _isDisposed = false;

    private void Callback(object? state)
    {
        if (_isDisposed) return;
        _currentTime = DateTime.Now;
        InvokeAsync(() =>
        {
            if (!_isDisposed)
            {
                StateHasChanged();
            }
        });
    }

    private void NavToCorpses() => Navigation.NavigateTo("/admin/corpses");
    private void NavToTemperature() => Navigation.NavigateTo("/admin/temperature");

    public void Dispose()
    {
        _isDisposed = true;
        _timer?.Dispose();
    }
}
