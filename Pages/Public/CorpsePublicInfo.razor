@page "/public/corpses/{CaseId}"
@inject Supabase.Client Supabase
@inject NavigationManager Navigation

<PageTitle>Thông tin Hồ sơ thi thể @_corpse?.Name - MorgueManager</PageTitle>

<div class="public-info-container">
    <!-- Header -->
    <header class="public-info-header">
        <a href="/" class="header-logo">
            <span class="logo-morgue">Morgue</span><span class="logo-manager">| Manager</span>
        </a>
        <a href="/login" class="header-login-btn">Portal</a>
    </header>

    @if (_loading)
    {
        <div class="loader-container">
            <div class="premium-spinner"></div>
            <p>Đang truy vấn thông tin hồ sơ bảo mật...</p>
        </div>
    }
    else if (_corpse == null)
    {
        <div class="error-card">
            <div class="error-icon">⚠️</div>
            <h2>Không tìm thấy dữ liệu</h2>
            <p>Mã hồ sơ <strong>@CaseId</strong> không tồn tại trên hệ thống hoặc đã được bàn giao, xóa bỏ.</p>
            <a href="/" class="btn-primary">Quay lại trang chủ</a>
        </div>
    }
    else
    {
        <div class="info-content animate-fade-in">
            <!-- Main Badge/Profile Card -->
            <div class="profile-card">
                <div class="avatar-circle">👤</div>
                <h1 class="corpse-name">@_corpse.Name</h1>
                <div class="status-badge-container">
                    <span class="status-badge status-@_corpse.Status.ToLower().Replace(" ", "-")">
                        @_corpse.Status
                    </span>
                </div>
                
                <div class="meta-grid">
                    <div class="meta-item">
                        <span class="meta-label">Mã thi thể</span>
                        <span class="meta-val monospace">@_corpse.CaseId</span>
                    </div>
                    <div class="meta-item">
                        <span class="meta-label">Vị trí ngăn</span>
                        <span class="meta-val">@(_corpse.StorageSlot ?? "Đã giải phóng")</span>
                    </div>
                </div>
            </div>

            <!-- Warning Retention Banner if any -->
            @if (!string.IsNullOrEmpty(GetRetentionWarning()))
            {
                <div class="warning-banner" style="border-color: @GetRetentionWarningColor(); color: @GetRetentionWarningColor(); background: rgba(0,0,0,0.15)">
                    <span class="warning-icon">📢</span>
                    <span class="warning-text">@GetRetentionWarning()</span>
                </div>
            }

            <!-- Details Section -->
            <div class="section-card">
                <h2 class="section-title">📊 Thông tin hành chính</h2>
                <div class="details-list">
                    <div class="detail-row">
                        <span class="lbl">Giới tính</span>
                        <span class="val">@_corpse.Gender</span>
                    </div>
                    <div class="detail-row">
                        <span class="lbl">Ngày sinh</span>
                        <span class="val">@_corpse.BirthDate</span>
                    </div>
                    <div class="detail-row">
                        <span class="lbl">Ngày tử vong</span>
                        <span class="val">@_corpse.DateOfDeath</span>
                    </div>
                    <div class="detail-row">
                        <span class="lbl">Nguyên nhân tử vong</span>
                        <span class="val">@_corpse.CauseOfDeath</span>
                    </div>
                    <div class="detail-row">
                        <span class="lbl">Ngày tiếp nhận</span>
                        <span class="val">@_corpse.DateAdmitted</span>
                    </div>
                    <div class="detail-row">
                        <span class="lbl">Chế độ lưu trữ</span>
                        <span class="val">@(_corpse.RequiresDeepFreeze ? "Đông sâu (-16°C)" : "Lạnh thường (2-4°C)")</span>
                    </div>
                    <div class="detail-row">
                        <span class="lbl">Nhóm lây nhiễm</span>
                        <span class="val @(_corpse.IsInfectious ? "infectious-text" : "")">
                            @(_corpse.IsInfectious ? _corpse.InfectiousGroup : "Không")
                        </span>
                    </div>
                    <div class="detail-row">
                        <span class="lbl">Số giấy chứng tử</span>
                        <span class="val">@(_corpse.DeathCertificateId == "" ? "Chưa cập nhật" : _corpse.DeathCertificateId)</span>
                    </div>
                </div>
            </div>

            <!-- Storage & Temperature -->
            @if (_corpse.Temp.HasValue)
            {
                <div class="section-card">
                    <h2 class="section-title">❄️ Giám sát nhiệt độ hộc lạnh</h2>
                    <div class="temp-display-box">
                        <span class="temp-val">@_corpse.Temp.Value.ToString("0.0")°C</span>
                        <span class="temp-status">✅ Ổn định (Thời gian thực)</span>
                    </div>
                </div>
            }

            <!-- Belongings -->
            <div class="section-card">
                <h2 class="section-title">💼 Tư trang đi kèm</h2>
                @if (_corpse.Belongings != null && _corpse.Belongings.Count > 0)
                {
                    <div class="belongings-list">
                        @foreach (var b in _corpse.Belongings)
                        {
                            <div class="belonging-item">
                                <div class="belonging-icon">📦</div>
                                <div class="belonging-info">
                                    <div class="belonging-name">@b.Name</div>
                                    <div class="belonging-desc">@b.Desc - Tình trạng: <em>@b.Condition</em></div>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <p class="no-data">Không có tư trang kèm theo hồ sơ.</p>
                }
            </div>

            <!-- Contact Next of Kin -->
            @if (!string.IsNullOrEmpty(_corpse.NextOfKin.Name))
            {
                <div class="section-card">
                    <h2 class="section-title">📞 Thông tin liên hệ thân nhân</h2>
                    <div class="nok-card">
                        <div class="nok-name">@_corpse.NextOfKin.Name (@_corpse.NextOfKin.Relationship)</div>
                        <a href="tel:@_corpse.NextOfKin.Phone" class="nok-phone-btn">
                            <span>📞 Gọi trực tiếp: @_corpse.NextOfKin.Phone</span>
                        </a>
                    </div>
                </div>
            }

            <!-- History log -->
            @if (_corpse.History != null && _corpse.History.Count > 0)
            {
                <div class="section-card">
                    <h2 class="section-title">⏱️ Lịch sử xử lý</h2>
                    <div class="timeline">
                        @foreach (var h in _corpse.History)
                        {
                            <div class="timeline-item">
                                <div class="timeline-marker"></div>
                                <div class="timeline-content">
                                    <div class="timeline-title">@h.Status — @h.Detail</div>
                                    <div class="timeline-meta">@h.Timestamp - @h.By</div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    }
</div>

<style>
    .public-info-container {
        max-width: 540px;
        margin: 0 auto;
        padding: 16px;
        min-height: 100vh;
        color: var(--text-primary);
        font-family: 'Inter', sans-serif;
    }

    .public-info-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 12px 4px;
        margin-bottom: 20px;
        border-bottom: 1px solid var(--border-primary);
    }

    .header-logo {
        text-decoration: none;
        font-family: 'Playfair Display', serif;
        font-size: 18px;
        font-weight: 700;
    }

    .logo-morgue {
        color: var(--text-primary);
    }

    .logo-manager {
        color: var(--ice);
    }

    .header-login-btn {
        font-size: 12px;
        padding: 6px 12px;
        border-radius: 6px;
        border: 1px solid var(--border-primary);
        color: var(--text-secondary);
        text-decoration: none;
        background: rgba(255,255,255,0.02);
        transition: all 0.3s;
    }

    .header-login-btn:hover {
        border-color: var(--ice);
        color: var(--text-primary);
    }

    .loader-container {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 80px 20px;
        text-align: center;
        color: var(--text-muted);
    }

    .premium-spinner {
        width: 40px;
        height: 40px;
        border: 3px solid rgba(72, 219, 251, 0.1);
        border-top-color: var(--ice);
        border-radius: 50%;
        animation: spin 1s linear infinite;
        margin-bottom: 16px;
    }

    .error-card {
        background: var(--bg-card);
        border: 1px solid var(--border-primary);
        border-radius: 12px;
        padding: 32px 24px;
        text-align: center;
        box-shadow: var(--shadow-md);
    }

    .error-icon {
        font-size: 40px;
        margin-bottom: 12px;
    }

    .error-card h2 {
        font-size: 20px;
        margin: 0 0 8px;
        font-weight: 600;
    }

    .error-card p {
        font-size: 14px;
        color: var(--text-secondary);
        margin: 0 0 24px;
    }

    .btn-primary {
        display: inline-block;
        background: var(--ice);
        color: #0f172a;
        padding: 10px 20px;
        border-radius: 8px;
        font-size: 14px;
        font-weight: 600;
        text-decoration: none;
        transition: opacity 0.2s;
    }

    .btn-primary:hover {
        opacity: 0.9;
    }

    .profile-card {
        background: var(--bg-card);
        border: 1px solid var(--border-primary);
        border-radius: 16px;
        padding: 24px;
        text-align: center;
        margin-bottom: 16px;
        box-shadow: var(--shadow-sm);
    }

    .avatar-circle {
        font-size: 44px;
        width: 72px;
        height: 72px;
        border-radius: 50%;
        background: var(--bg-elevated);
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 12px;
    }

    .corpse-name {
        font-size: 22px;
        font-weight: 700;
        margin: 0 0 8px;
        color: var(--text-primary);
    }

    .status-badge-container {
        margin-bottom: 20px;
    }

    .status-badge {
        font-size: 11px;
        font-weight: 600;
        text-transform: uppercase;
        padding: 4px 10px;
        border-radius: 9999px;
        letter-spacing: 0.05em;
    }

    .status-tiếp-nhận {
        background: rgba(72,219,251,0.15);
        color: var(--ice);
        border: 1px solid rgba(72,219,251,0.3);
    }

    .status-lưu-kho {
        background: rgba(9,132,227,0.15);
        color: #74b9ff;
        border: 1px solid rgba(9,132,227,0.3);
    }

    .status-bàn-giao {
        background: rgba(46,204,113,0.15);
        color: var(--success);
        border: 1px solid rgba(46,204,113,0.3);
    }

    .meta-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
        border-top: 1px solid var(--border-primary);
        padding-top: 16px;
    }

    .meta-item {
        display: flex;
        flex-direction: column;
        text-align: center;
    }

    .meta-label {
        font-size: 10px;
        text-transform: uppercase;
        color: var(--text-muted);
        margin-bottom: 4px;
        letter-spacing: 0.05em;
    }

    .meta-val {
        font-size: 14px;
        font-weight: 600;
        color: var(--text-primary);
    }

    .monospace {
        font-family: monospace;
    }

    .warning-banner {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 12px 16px;
        border-radius: 12px;
        border: 1px solid;
        margin-bottom: 16px;
        font-size: 13px;
        font-weight: 600;
    }

    .section-card {
        background: var(--bg-card);
        border: 1px solid var(--border-primary);
        border-radius: 16px;
        padding: 20px;
        margin-bottom: 16px;
        box-shadow: var(--shadow-sm);
    }

    .section-title {
        font-size: 15px;
        font-weight: 600;
        margin: 0 0 16px;
        color: var(--text-primary);
        border-bottom: 1px solid var(--border-primary);
        padding-bottom: 8px;
    }

    .details-list {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .detail-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-size: 13px;
    }

    .lbl {
        color: var(--text-muted);
    }

    .val {
        font-weight: 500;
        color: var(--text-primary);
    }

    .infectious-text {
        color: var(--danger);
        font-weight: 700;
    }

    .temp-display-box {
        display: flex;
        justify-content: space-between;
        align-items: center;
        background: var(--bg-elevated);
        padding: 12px 16px;
        border-radius: 10px;
    }

    .temp-val {
        font-size: 20px;
        font-weight: 700;
        color: var(--success);
    }

    .temp-status {
        font-size: 12px;
        color: var(--text-secondary);
    }

    .belongings-list {
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

    .belonging-item {
        display: flex;
        gap: 12px;
        align-items: center;
        background: var(--bg-elevated);
        padding: 10px 12px;
        border-radius: 8px;
    }

    .belonging-icon {
        font-size: 18px;
    }

    .belonging-name {
        font-size: 13px;
        font-weight: 600;
        color: var(--text-primary);
    }

    .belonging-desc {
        font-size: 11px;
        color: var(--text-muted);
    }

    .nok-card {
        background: var(--bg-elevated);
        padding: 12px 16px;
        border-radius: 10px;
    }

    .nok-name {
        font-size: 14px;
        font-weight: 600;
        margin-bottom: 10px;
        color: var(--text-primary);
    }

    .nok-phone-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(46,204,113,0.15);
        color: var(--success);
        border: 1px solid rgba(46,204,113,0.3);
        border-radius: 8px;
        padding: 8px;
        text-decoration: none;
        font-size: 13px;
        font-weight: 600;
        transition: opacity 0.2s;
    }

    .nok-phone-btn:hover {
        opacity: 0.9;
    }

    .timeline {
        display: flex;
        flex-direction: column;
        gap: 16px;
        position: relative;
        padding-left: 16px;
    }

    .timeline::before {
        content: '';
        position: absolute;
        left: 4px;
        top: 4px;
        bottom: 4px;
        width: 2px;
        background: var(--border-primary);
    }

    .timeline-item {
        position: relative;
    }

    .timeline-marker {
        position: absolute;
        left: -16px;
        top: 4px;
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: var(--ice);
        border: 2px solid var(--bg-card);
    }

    .timeline-title {
        font-size: 13px;
        font-weight: 600;
        color: var(--text-primary);
    }

    .timeline-meta {
        font-size: 11px;
        color: var(--text-muted);
        margin-top: 2px;
    }

    .no-data {
        font-size: 13px;
        color: var(--text-muted);
        margin: 0;
    }

    .animate-fade-in {
        animation: fadeIn 0.4s ease-out forwards;
    }

    @@keyframes spin {
        to { transform: rotate(360deg); }
    }

    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>

@code {
    [Parameter] public string CaseId { get; set; } = "";

    private Models.Corpse? _corpse;
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var response = await Supabase.From<Models.Corpse>().Where(x => x.CaseId == CaseId).Get();
            _corpse = response.Models.FirstOrDefault();
        }
        catch (Exception ex)
        {
            Console.WriteLine("Error loading public corpse details: " + ex.Message);
        }
        finally
        {
            _loading = false;
        }
    }

    private string GetRetentionWarning()
    {
        if (_corpse == null || string.IsNullOrEmpty(_corpse.DateAdmitted)) return "";
        if (!DateTime.TryParseExact(_corpse.DateAdmitted, new[] { "dd-MM-yyyy", "yyyy-MM-dd", "dd/MM/yyyy", "MM/dd/yyyy" }, null, System.Globalization.DateTimeStyles.None, out var admitDate)) return "";

        var elapsedHours = (DateTime.Now - admitDate).TotalHours;
        var elapsedDays = (DateTime.Now - admitDate).TotalDays;

        if (_corpse.IsInfectious)
        {
            var remainingHours = 24 - elapsedHours;
            if (remainingHours < 0) return "QUÁ HẠN LÂY NHIỄM (> 24H)!";
            return $"Lây nhiễm: Còn {Math.Max(0, remainingHours):F1}h lưu giữ.";
        }

        if (_corpse.IsUnidentified)
        {
            var remainingDays = 30 - elapsedDays;
            if (remainingDays < 0) return "QUÁ HẠN VÔ DANH (> 30 NGÀY)!";
            return $"Vô danh: Còn {Math.Max(0, remainingDays):F0} ngày tìm thân nhân.";
        }

        if (_corpse.RequiresDeepFreeze)
        {
            return "Lưu đông sâu: Chờ thủ tục pháp y.";
        }

        var normRemaining = 7 - elapsedDays;
        if (normRemaining < 0) return "QUÁ HẠN THÔNG THƯỜNG (> 7 NGÀY)!";
        return $"Lưu trữ thông thường: Còn {Math.Max(0, normRemaining):F0} ngày.";
    }

    private string GetRetentionWarningColor()
    {
        var text = GetRetentionWarning();
        if (text.Contains("QUÁ HẠN") || text.Contains("Lây nhiễm")) return "var(--danger)";
        if (text.Contains("Vô danh")) return "orange";
        return "var(--ice)";
    }
}
