@inherits LayoutComponentBase
@inject NavigationManager Navigation
@inject AuthService AuthService

@if (!_authChecked)
{
    <div class="font-ui" style="display: flex; align-items: center; justify-content: center; min-height: 100vh; color: var(--text-muted); font-size: 14px;">
        ⏳ Đang tải...
    </div>
}
else
{
    <style>
        .admin-content-wrapper {
            margin-left: var(--sidebar-width);
        }
        .admin-content-wrapper.collapsed {
            margin-left: 0;
        }
        .mobile-overlay {
            display: none;
            position: fixed;
            inset: 0;
            background-color: rgba(0,0,0,0.5);
            z-index: 30;
        }
        @@media (max-width: 768px) {
            .admin-content-wrapper {
                margin-left: 0 !important;
            }
            .mobile-overlay.active {
                display: block;
            }
        }
    </style>

    <div class="flex min-h-screen">
        <Sidebar IsCollapsed="_sidebarCollapsed" />
        
        <div class="mobile-overlay @(_sidebarCollapsed ? "" : "active")" @onclick="ToggleSidebar"></div>

        <div class="flex-1 flex flex-col transition-all duration-300 admin-content-wrapper @(_sidebarCollapsed ? "collapsed" : "")">
            <TopBar IsCollapsed="_sidebarCollapsed" OnToggleSidebar="ToggleSidebar" />
            <main class="flex-1 p-6" style="margin-top: var(--topbar-height); background-color: var(--bg-primary);">
                @Body
            </main>
        </div>
    </div>

}

@code {
    private bool _sidebarCollapsed;
    private bool _authChecked;

    protected override async Task OnInitializedAsync()
    {
        var isLoggedIn = await AuthService.IsLoggedInAsync();
        if (!isLoggedIn)
        {
            Navigation.NavigateTo("/login");
            return;
        }
        _authChecked = true;
    }

    private void ToggleSidebar()
    {
        _sidebarCollapsed = !_sidebarCollapsed;
    }
}
