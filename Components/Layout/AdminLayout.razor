@inherits LayoutComponentBase
@inject NavigationManager Navigation
@inject AuthService AuthService

@if (!_authChecked)
{
    <div class="font-ui" style="display: flex; align-items: center; justify-content: center; min-height: 100vh; color: var(--text-muted); font-size: 14px;">
        ⏳ Đang tải...
    </div>
}
else
{
    <div class="flex min-h-screen">
        <Sidebar IsCollapsed="_sidebarCollapsed" />
        <div class="flex-1 flex flex-col transition-all duration-300" style="margin-left: @(_sidebarCollapsed ? "0" : "var(--sidebar-width)")">
            <TopBar IsCollapsed="_sidebarCollapsed" OnToggleSidebar="ToggleSidebar" />
            <main class="flex-1 p-6" style="margin-top: var(--topbar-height); background-color: var(--bg-primary);">
                @Body
            </main>
        </div>
    </div>

}

@code {
    private bool _sidebarCollapsed;
    private bool _authChecked;

    protected override async Task OnInitializedAsync()
    {
        var isLoggedIn = await AuthService.IsLoggedInAsync();
        if (!isLoggedIn)
        {
            Navigation.NavigateTo("/login");
            return;
        }
        _authChecked = true;
    }

    private void ToggleSidebar()
    {
        _sidebarCollapsed = !_sidebarCollapsed;
    }
}
