<div class="slot-card" style="border: 2px solid @_borderColor; background-color: @_bgColor; box-shadow: @_currentShadow;"
     @onmouseover="OnMouseOver" @onmouseout="OnMouseOut" @onclick="HandleClick">
    <div style="display: flex; justify-content: space-between; margin-bottom: 8px;">
        <span class="font-ui" style="font-weight: 700; font-size: 14px; color: var(--text-primary);">@Slot.Id</span>
        @if (ShowTemp)
        {
            <span style="font-size: 12px; font-family: monospace; font-weight: 600; color: @_tempColor;">🌡️ @Slot.Temp.ToString("F1")°C</span>
        }
    </div>
    <div style="display: flex; flex-direction: column; align-items: center; justify-content: center; flex: 1; padding: 8px 0; min-height: 0;">
        <span style="font-size: 18px; color: @_borderColor;">@_icon</span>
        @if ((_status == "occupied" || _status == "pending") && !string.IsNullOrEmpty(Slot.CorpseName))
        {
            <div style="text-align: center; margin-top: 4px; width: 100%;">
                <div class="font-ui" style="font-size: 12px; font-weight: 500; max-width: 100%; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; color: var(--text-primary);">@Slot.CorpseName</div>
                @if (_status == "occupied")
                {
                    <div class="font-ui" style="font-size: 10px; color: var(--text-muted);">@Slot.DaysStored ngày</div>
                }
                else
                {
                    <div class="font-ui" style="font-size: 10px; color: #EC4899; font-weight: 600;">Yêu cầu thuê</div>
                }
            </div>
        }
        else
        {
            <div class="font-ui" style="font-size: 10px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; margin-top: 4px; color: @_borderColor;">@_label</div>
        }
    </div>
    <div class="font-ui" style="font-size: 9px; text-align: center; margin-top: 4px; color: var(--text-muted);">Cập nhật: @Slot.LastUpdate</div>
    @if (Slot.Temp > 6)
    {
        <div class="animate-ping" style="position: absolute; top: -4px; right: -4px; width: 12px; height: 12px; border-radius: 50%; background-color: #EF4444;"></div>
    }
</div>

@code {
    [Parameter] public Models.StorageSlot Slot { get; set; } = new();
    [Parameter] public bool ShowTemp { get; set; } = true;
    [Parameter] public EventCallback<Models.StorageSlot> OnClick { get; set; }

    private string _borderColor = "#10B981";
    private string _bgColor = "rgba(16,185,129,0.06)";
    private string _glowColor = "0 0 20px rgba(16,185,129,0.15)";
    private string _label = "Trống";
    private string _icon = "✅";
    private string _tempColor = "#10B981";
    private string _currentShadow = "none";
    private string _status = "empty";

    protected override void OnParametersSet()
    {
        switch (Slot.Status)
        {
            case Models.SlotStatus.Empty:
                _borderColor = "#10B981"; _bgColor = "rgba(16,185,129,0.06)"; _glowColor = "0 0 20px rgba(16,185,129,0.15)"; _label = "Trống"; _icon = "✅"; _status = "empty";
                break;
            case Models.SlotStatus.Occupied:
                if (string.Equals(Slot.PackageName, "deep", StringComparison.OrdinalIgnoreCase))
                {
                    _borderColor = "#48DBFB"; _bgColor = "rgba(72,219,251,0.06)"; _glowColor = "0 0 20px rgba(72,219,251,0.2)"; _label = "Thuê - Lạnh Sâu"; _icon = "❄️"; _status = "occupied";
                }
                else if (string.Equals(Slot.PackageName, "Forensic", StringComparison.OrdinalIgnoreCase))
                {
                    _borderColor = "#F59E0B"; _bgColor = "rgba(245,158,11,0.06)"; _glowColor = "0 0 20px rgba(245,158,11,0.2)"; _label = "Thuê - Pháp Y"; _icon = "⚖️"; _status = "occupied";
                }
                else if (string.Equals(Slot.PackageName, "standard", StringComparison.OrdinalIgnoreCase))
                {
                    _borderColor = "#EF4444"; _bgColor = "rgba(239,68,68,0.06)"; _glowColor = "0 0 20px rgba(239,68,68,0.2)"; _label = "Thuê - Tiêu Chuẩn"; _icon = "👤"; _status = "occupied";
                }
                else
                {
                    _borderColor = "#EF4444"; _bgColor = "rgba(239,68,68,0.06)"; _glowColor = "0 0 20px rgba(239,68,68,0.15)"; _label = ""; _icon = "👤"; _status = "occupied";
                }
                break;
            case Models.SlotStatus.Pending:
                _borderColor = "#EC4899"; _bgColor = "rgba(236,72,153,0.06)"; _glowColor = "0 0 20px rgba(236,72,153,0.15)"; _label = "Đang xử lý (24h)"; _icon = "🌸"; _status = "pending";
                break;
            case Models.SlotStatus.Cleaning:
                _borderColor = "#F59E0B"; _bgColor = "rgba(245,158,11,0.06)"; _glowColor = "0 0 20px rgba(245,158,11,0.15)"; _label = "Đang vệ sinh"; _icon = "🧹"; _status = "cleaning";
                break;
            case Models.SlotStatus.Maintenance:
                _borderColor = "#6366F1"; _bgColor = "rgba(99,102,241,0.06)"; _glowColor = "0 0 20px rgba(99,102,241,0.15)"; _label = "Bảo trì"; _icon = "🔧"; _status = "maintenance";
                break;
        }
        _tempColor = Slot.Temp > 6 ? "#EF4444" : Slot.Temp > 4 ? "#F59E0B" : "#10B981";
        _currentShadow = Slot.Temp > 6 ? "0 0 20px rgba(239,68,68,0.3)" : "none";
    }

    private void OnMouseOver() { _currentShadow = _glowColor; }
    private void OnMouseOut() { _currentShadow = Slot.Temp > 6 ? "0 0 20px rgba(239,68,68,0.3)" : "none"; }
    private async Task HandleClick() { await OnClick.InvokeAsync(Slot); }
}
