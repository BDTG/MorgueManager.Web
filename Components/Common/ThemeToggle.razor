@inject IJSRuntime JS

<button @onclick="ToggleTheme" class="p-2 rounded-lg transition-all duration-300 hover:bg-black/5 dark:hover:bg-white/5 flex-shrink-0" style="background: transparent; border: none; cursor: pointer; color: @(_isDark ? "#facc15" : "#64748b");" aria-label="Toggle theme">
    @if (_isDark)
    {
        <LucideIcon Name="sun" Class="w-5 h-5" />
    }
    else
    {
        <LucideIcon Name="moon" Class="w-5 h-5" />
    }
</button>

@code {
    private bool _isDark = true;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                var theme = await JS.InvokeAsync<string>("localStorage.getItem", "morguemanager-theme");
                _isDark = theme != "light";
                StateHasChanged();
            }
            catch
            {
                // Ignored
            }
        }
    }

    private async Task ToggleTheme()
    {
        _isDark = !_isDark;
        StateHasChanged(); // Force update UI immediately
        var theme = _isDark ? "dark" : "light";
        try
        {
            await JS.InvokeVoidAsync("localStorage.setItem", "morguemanager-theme", theme);
            await JS.InvokeVoidAsync("document.documentElement.setAttribute", "data-theme", theme);
        }
        catch
        {
            // Ignored
        }
    }
}
